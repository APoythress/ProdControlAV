# ProdControlAV Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to source control - it contains sensitive data

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Azure SQL Database connection string
# Format: Server=tcp:<server>.database.windows.net,1433;Initial Catalog=<database>;Persist Security Info=False;User ID=<username>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
DB_CONNECTION_STRING=Server=tcp:your-server.database.windows.net,1433;Initial Catalog=YourDatabase;Persist Security Info=False;User ID=your-username;Password=your-password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;

# =============================================================================
# JWT AUTHENTICATION CONFIGURATION
# =============================================================================
# JWT token issuer (typically your API domain)
JWT_ISSUER=https://your-api-domain.com

# JWT token audience (typically your API domain or client app)
JWT_AUDIENCE=https://your-api-domain.com

# JWT signing key (IMPORTANT: Generate a secure random key, minimum 32 characters)
# Example generation: openssl rand -base64 32
JWT_KEY=your-secure-jwt-signing-key-minimum-32-characters-long

# =============================================================================
# AZURE STORAGE CONFIGURATION
# =============================================================================
# Azure Table Storage endpoint (using Managed Identity / DefaultAzureCredential)
# Format: https://<storage-account>.table.core.windows.net/
TABLES_ENDPOINT=https://your-storage-account.table.core.windows.net/

# Alternative: Azure Table Storage connection string (if not using Managed Identity)
# Format: DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
# TABLES_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net

# Azure Queue Storage connection string for agent commands
# Format: DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
QUEUE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net

# =============================================================================
# AGENT CONFIGURATION (for API authentication)
# =============================================================================
# API key for agent authentication (minimum 32 characters)
# Example generation: openssl rand -base64 32
AGENT_API_KEY=your-secure-agent-api-key-minimum-32-characters-long

# =============================================================================
# ASPNETCORE CONFIGURATION (Runtime Settings)
# =============================================================================
# Environment setting (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Development

# Application URLs (comma-separated list)
# For Docker: typically http://0.0.0.0:8080
# For local dev: https://localhost:5001;http://localhost:5000
ASPNETCORE_URLS=https://localhost:5001;http://localhost:5000

# =============================================================================
# NOTES
# =============================================================================
# 1. For local development with Rider/Visual Studio:
#    - Set these variables in launchSettings.json or your IDE's run configuration
#    - Or use dotnet user-secrets for sensitive data
#
# 2. For Docker development:
#    - Copy .env.example to .env and fill in values
#    - Use docker-compose up to start the application
#    - Docker Compose will automatically load .env file
#
# 3. For Azure deployment:
#    - Set these as Application Settings in Azure App Service
#    - Use Azure Key Vault references for sensitive values
#    - Connection strings can be set in the Connection Strings section
#
# 4. Security Best Practices:
#    - NEVER commit .env file to source control
#    - Use different values for each environment
#    - Rotate keys regularly
#    - Use Managed Identity when possible instead of connection strings
