@page "/Locations"
@using System.Net.Http
@using System.Net.Http.Json
@using System.Threading

@inject HttpClient Http
@inject IJSRuntime JsRuntime

<div class="container mt-5 text-white">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><u>Location Management</u></h3>
    </div>

    @if (loading)
    {
        <div class="text-center">
            <div class="spinner-border text-light" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (!agents.Any())
    {
        <div class="alert alert-info">
            No agents found. Contact support to set up an agent for your location.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-striped table-hover">
                <thead>
                    <tr>
                        <th>Location Name</th>
                        <th>Status</th>
                        <th>Version</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var agent in agents)
                    {
                        <tr>
                            <td>@agent.Name</td>
                            <td>
                                <span class="badge @(agent.IsOnline ? "bg-success" : "bg-secondary")">
                                    @(agent.IsOnline ? "Online" : "Offline")
                                </span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <span>@(agent.Version ?? "Unknown")</span>
                                    @if (!string.IsNullOrEmpty(agent.Version) && latestVersion != null && IsUpdateAvailable(agent.Version, latestVersion))
                                    {
                                        <span class="ms-2" 
                                              style="cursor: pointer; color: #28a745;"
                                              title="@GetUpdateTooltip()">
                                            <i class="fas fa-arrow-up"></i>
                                        </span>
                                    }
                                </div>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-warning" 
                                        @onclick="@(() => ShowRestartConfirmation(agent))"
                                        title="Restart Agent">
                                    <i class="fas fa-sync-alt"></i> Restart
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Restart Confirmation Modal -->
    <div class="modal fade" id="restartModal" tabindex="-1" aria-labelledby="restartModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white">
                <div class="modal-header">
                    <h5 class="modal-title" id="restartModalLabel">Confirm Restart</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (selectedAgent != null)
                    {
                        <p><strong>Location:</strong> @selectedAgent.Name</p>
                        <p class="text-warning">
                            <i class="fas fa-exclamation-triangle"></i> 
                            Would you like to restart the agent?
                        </p>
                        <p class="text-muted small">
                            <strong>Note:</strong> A restart will trigger any pending updates either major or minor. 
                            If you are unsure of this please cancel and contact support for assistance.
                        </p>
                    }

                    @if (!string.IsNullOrEmpty(restartMessage))
                    {
                        <div class="alert @restartMessageCss mt-3" role="alert">
                            @restartMessage
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" @onclick="ConfirmRestart" disabled="@isRestarting">
                        @if (isRestarting)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            <text> Restarting...</text>
                        }
                        else
                        {
                            <text>Restart</text>
                        }
                    </button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<AgentDto> agents = new();
    private AgentDto? selectedAgent;
    private bool loading = true;
    private string? errorMessage;
    private bool isRestarting = false;
    private string? restartMessage;
    private string restartMessageCss = "alert-info";
    private string? latestVersion;
    private string? updateDescription;
    private bool isCriticalUpdate;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        errorMessage = null;
        
        try
        {
            // Load agents and update information in parallel
            var agentsTask = Http.GetFromJsonAsync<List<AgentDto>>("api/agents/list");
            var updatesTask = Http.GetFromJsonAsync<UpdateInfoDto>("api/agents/updates/available");
            
            await Task.WhenAll(agentsTask, updatesTask);
            
            agents = agentsTask.Result ?? new();
            
            var updateInfo = updatesTask.Result;
            if (updateInfo != null)
            {
                latestVersion = updateInfo.LatestVersion;
                updateDescription = updateInfo.Description;
                isCriticalUpdate = updateInfo.IsCritical;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading data: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ShowRestartConfirmation(AgentDto agent)
    {
        selectedAgent = agent;
        restartMessage = null;
        await ShowModal("restartModal");
    }

    private async Task ConfirmRestart()
    {
        if (selectedAgent == null) return;

        isRestarting = true;
        restartMessage = null;
        StateHasChanged();

        try
        {
            var response = await Http.PostAsync($"api/agents/{selectedAgent.AgentId}/restart", null);
            var result = await response.Content.ReadFromJsonAsync<RestartResponse>();

            if (response.IsSuccessStatusCode && result?.Success == true)
            {
                restartMessage = result.Message ?? "Restart command sent successfully";
                restartMessageCss = "alert-success";
                
                // Close modal after 2 seconds
                await Task.Delay(2000);
                await HideModal("restartModal");
                await LoadData();
            }
            else
            {
                restartMessage = result?.Error ?? $"Failed: {response.ReasonPhrase}";
                restartMessageCss = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            restartMessage = $"Error: {ex.Message}";
            restartMessageCss = "alert-danger";
        }
        finally
        {
            isRestarting = false;
            StateHasChanged();
        }
    }

    private async Task ShowModal(string modalId)
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("eval", $"new bootstrap.Modal(document.getElementById('{modalId}')).show()");
        }
        catch (Exception) { }
    }

    private async Task HideModal(string modalId)
    {
        try
        {
            await JsRuntime.InvokeVoidAsync("eval", $"bootstrap.Modal.getInstance(document.getElementById('{modalId}')).hide()");
        }
        catch (Exception) { }
    }

    private bool IsUpdateAvailable(string currentVersion, string latestVersion)
    {
        if (string.IsNullOrEmpty(currentVersion) || string.IsNullOrEmpty(latestVersion))
            return false;

        try
        {
            // Remove 'v' prefix if present
            var current = currentVersion.TrimStart('v');
            var latest = latestVersion.TrimStart('v');

            var currentParts = current.Split('.');
            var latestParts = latest.Split('.');

            // Compare version parts
            for (int i = 0; i < Math.Max(currentParts.Length, latestParts.Length); i++)
            {
                int currentPart = i < currentParts.Length && int.TryParse(currentParts[i], out var cp) ? cp : 0;
                int latestPart = i < latestParts.Length && int.TryParse(latestParts[i], out var lp) ? lp : 0;

                if (latestPart > currentPart)
                    return true;
                if (latestPart < currentPart)
                    return false;
            }

            return false; // Versions are equal
        }
        catch
        {
            return false;
        }
    }

    private string GetUpdateTooltip()
    {
        if (string.IsNullOrEmpty(latestVersion))
            return "Update available";

        var updateType = GetUpdateType();
        var tooltip = $"New version {latestVersion} available";
        
        if (!string.IsNullOrEmpty(updateDescription))
        {
            tooltip += $"\n{updateDescription}";
        }
        
        tooltip += $"\n{updateType} update";
        
        return tooltip;
    }

    private string GetUpdateType()
    {
        if (isCriticalUpdate)
            return "CRITICAL";

        if (string.IsNullOrEmpty(latestVersion))
            return "MINOR";

        try
        {
            // Find the first agent with a version to compare
            var currentVersion = agents.FirstOrDefault(a => !string.IsNullOrEmpty(a.Version))?.Version;
            if (string.IsNullOrEmpty(currentVersion))
                return "MINOR";

            var current = currentVersion.TrimStart('v').Split('.');
            var latest = latestVersion.TrimStart('v').Split('.');

            if (current.Length > 0 && latest.Length > 0)
            {
                // Major version change (first number)
                if (int.TryParse(current[0], out var currentMajor) && 
                    int.TryParse(latest[0], out var latestMajor) && 
                    latestMajor > currentMajor)
                {
                    return "MAJOR";
                }

                // Minor version change (second number)
                if (current.Length > 1 && latest.Length > 1 &&
                    int.TryParse(current[1], out var currentMinor) && 
                    int.TryParse(latest[1], out var latestMinor) && 
                    latestMinor > currentMinor)
                {
                    return "MINOR";
                }
            }

            return "MINOR";
        }
        catch
        {
            return "MINOR";
        }
    }

    // DTOs
    private class AgentDto
    {
        public Guid AgentId { get; set; }
        public string Name { get; set; } = "";
        public string? Version { get; set; }
        public DateTimeOffset? LastSeenUtc { get; set; }
        public bool IsOnline { get; set; }
        public string? LastHostname { get; set; }
        public string? LastIp { get; set; }
    }

    private class UpdateInfoDto
    {
        public string? LatestVersion { get; set; }
        public string? Description { get; set; }
        public bool IsCritical { get; set; }
    }

    private class RestartResponse
    {
        public bool Success { get; set; }
        public string? Message { get; set; }
        public string? Error { get; set; }
    }
}
