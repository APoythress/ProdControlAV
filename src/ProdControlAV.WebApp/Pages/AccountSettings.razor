@page "/account"
@using System.Net.Http.Json
@using ProdControlAV.Core.Models
@using System.Net.Http
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<PageTitle>Account Settings - ProdControlAV</PageTitle>

<div class="container-fluid min-vh-100 d-flex align-items-center justify-content-center py-5">
    <div class="row w-100 justify-content-center">
        <div class="col-12 col-lg-10 col-xl-8">
            <!-- Title Header -->
            <div class="text-center mb-5">
                <h1 class="display-5 fw-bold text-white mb-3">
                    <i class="bi bi-person-circle me-3"></i>Account Settings
                </h1>
                <p class="lead text-white-50">
                    Manage your subscription plan and notification preferences
                </p>
            </div>

            @if (_isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-light" style="width: 3rem; height: 3rem;" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="text-white-50 mt-3">Loading account information...</p>
                </div>
            }
            else if (_errorMessage != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>Error:</strong> @_errorMessage
                    <button type="button" class="btn-close" @onclick="@(() => _errorMessage = null)"></button>
                </div>
            }
            else if (_plan != null)
            {
                <!-- Subscription Plan Card -->
                <div class="card bg-dark border-light shadow-lg mb-4">
                    <div class="card-header bg-secondary border-light">
                        <h5 class="text-white mb-0">
                            <i class="bi bi-award me-2"></i>Subscription Plan
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-md-6">
                                <h4 class="text-white mb-2">
                                    @if (_plan.CurrentPlan == SubscriptionPlan.Pro)
                                    {
                                        <span class="badge bg-success fs-5">
                                            <i class="bi bi-star-fill me-2"></i>Pro Plan
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary fs-5">
                                            <i class="bi bi-circle-fill me-2"></i>Base Plan
                                        </span>
                                    }
                                </h4>
                                <p class="text-white-50 mb-0">
                                    @if (_plan.CurrentPlan == SubscriptionPlan.Pro)
                                    {
                                        <span>SMS notifications enabled</span>
                                    }
                                    else
                                    {
                                        <span>Basic monitoring features</span>
                                    }
                                </p>
                            </div>
                            <div class="col-md-6 text-md-end mt-3 mt-md-0">
                                @if (_plan.CanUpgrade)
                                {
                                    <button class="btn btn-primary btn-lg" @onclick="UpgradeToPro" disabled="@_isUpgrading">
                                        @if (_isUpgrading)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                        }
                                        <i class="bi bi-arrow-up-circle me-2"></i>Upgrade to Pro
                                    </button>
                                }
                                else
                                {
                                    <span class="badge bg-success fs-6">
                                        <i class="bi bi-check-circle me-2"></i>Active
                                    </span>
                                }
                            </div>
                        </div>

                        @if (_plan.CurrentPlan == SubscriptionPlan.Base)
                        {
                            <hr class="border-light my-4" />
                            <div class="alert alert-info mb-0">
                                <h6 class="alert-heading">
                                    <i class="bi bi-info-circle-fill me-2"></i>Upgrade to Pro
                                </h6>
                                <p class="mb-0">Get SMS notifications when devices go offline with last seen times.</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- SMS Notifications Card (Pro Plan Only) -->
                @if (_plan.CurrentPlan == SubscriptionPlan.Pro)
                {
                    <div class="card bg-dark border-light shadow-lg">
                        <div class="card-header bg-secondary border-light">
                            <h5 class="text-white mb-0">
                                <i class="bi bi-phone me-2"></i>SMS Notifications
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" role="switch" 
                                           id="smsEnabled" 
                                           @bind="_smsEnabled"
                                           disabled="@_isSaving">
                                    <label class="form-check-label text-white" for="smsEnabled">
                                        Enable SMS notifications for offline devices
                                    </label>
                                </div>
                                <small class="text-white-50">
                                    Receive text messages when monitored devices go offline
                                </small>
                            </div>

                            <div class="mb-4">
                                <label for="phoneNumber" class="form-label text-white">
                                    <i class="bi bi-phone-vibrate me-2"></i>Phone Number
                                </label>
                                <input type="tel" 
                                       class="form-control form-control-lg bg-secondary text-white border-light" 
                                       id="phoneNumber"
                                       placeholder="+15551234567" 
                                       @bind="_phoneNumber"
                                       disabled="@(!_smsEnabled || _isSaving)">
                                <small class="text-white-50">
                                    Use E.164 format (e.g., +15551234567)
                                </small>
                                @if (!string.IsNullOrEmpty(_plan.MaskedPhoneNumber))
                                {
                                    <div class="mt-2">
                                        <small class="text-info">
                                            <i class="bi bi-shield-check me-1"></i>
                                            Current: @_plan.MaskedPhoneNumber
                                        </small>
                                    </div>
                                }
                            </div>

                            <button class="btn btn-success" @onclick="SaveSmsPreferences" disabled="@_isSaving">
                                @if (_isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                <i class="bi bi-save me-2"></i>Save Notification Settings
                            </button>

                            @if (_successMessage != null)
                            {
                                <div class="alert alert-success mt-3 mb-0">
                                    <i class="bi bi-check-circle-fill me-2"></i>@_successMessage
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private UserPlanDto? _plan;
    private bool _isLoading = true;
    private bool _isUpgrading = false;
    private bool _isSaving = false;
    private bool _smsEnabled = false;
    private string _phoneNumber = "";
    private string? _errorMessage;
    private string? _successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadPlanAsync();
    }

    private async Task LoadPlanAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;
            
            var response = await Http.GetAsync("api/userplan");
            
            if (response.IsSuccessStatusCode)
            {
                _plan = await response.Content.ReadFromJsonAsync<UserPlanDto>();
                
                if (_plan != null)
                {
                    _smsEnabled = _plan.SmsNotificationsEnabled;
                }
            }
            else
            {
                _errorMessage = $"Failed to load account information. Status: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading account information: {ex.Message}";
            Console.Error.WriteLine($"Error loading plan: {ex}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task UpgradeToPro()
    {
        try
        {
            _isUpgrading = true;
            _errorMessage = null;
            _successMessage = null;

            var request = new { NewPlan = SubscriptionPlan.Pro };
            var response = await Http.PostAsJsonAsync("api/userplan/upgrade", request);

            if (response.IsSuccessStatusCode)
            {
                _plan = await response.Content.ReadFromJsonAsync<UserPlanDto>();
                _successMessage = "Successfully upgraded to Pro plan!";
                await JSRuntime.InvokeVoidAsync("alert", "Successfully upgraded to Pro plan! You can now enable SMS notifications.");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                _errorMessage = $"Failed to upgrade plan: {error}";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error upgrading plan: {ex.Message}";
            Console.Error.WriteLine($"Error upgrading plan: {ex}");
        }
        finally
        {
            _isUpgrading = false;
        }
    }

    private async Task SaveSmsPreferences()
    {
        try
        {
            _isSaving = true;
            _errorMessage = null;
            _successMessage = null;

            // Validate phone number if SMS is enabled
            if (_smsEnabled && string.IsNullOrWhiteSpace(_phoneNumber))
            {
                _errorMessage = "Please enter a phone number to enable SMS notifications.";
                return;
            }

            var request = new 
            { 
                PhoneNumber = _smsEnabled ? _phoneNumber : null,
                SmsNotificationsEnabled = _smsEnabled
            };
            
            var response = await Http.PostAsJsonAsync("api/userplan/sms-preferences", request);

            if (response.IsSuccessStatusCode)
            {
                _plan = await response.Content.ReadFromJsonAsync<UserPlanDto>();
                _successMessage = "SMS notification preferences saved successfully!";
                _phoneNumber = ""; // Clear input after successful save
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                _errorMessage = $"Failed to save preferences: {error}";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error saving preferences: {ex.Message}";
            Console.Error.WriteLine($"Error saving SMS preferences: {ex}");
        }
        finally
        {
            _isSaving = false;
        }
    }

    // DTOs matching the API
    public record UserPlanDto(
        SubscriptionPlan CurrentPlan,
        bool CanUpgrade,
        bool SmsNotificationsEnabled,
        string? MaskedPhoneNumber
    );
}
