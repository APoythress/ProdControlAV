@page "/settings"
@using System.Net.Http
@using System.Net.Http.Json
@using ProdControlAV.Core.Models
@inject HttpClient Http
@inject DeviceApiClient deviceApiClient

<div class="container mt-5 text-white">
    <h3 class="text-center mb-4"><u>Device Ping Frequency Settings</u></h3>
    
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle"></i> Configure how often each device should be pinged by the monitoring agent. Lower frequencies reduce database load and costs.
    </div>
    
    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border text-light" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (devices == null || devices.Count == 0)
    {
        <div class="alert alert-warning" role="alert">
            No devices found. Please add devices first.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-striped table-hover">
                <thead>
                    <tr>
                        <th>Device Name</th>
                        <th>IP Address</th>
                        <th>Type</th>
                        <th>Ping Frequency (seconds)</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var device in devices)
                    {
                        <tr>
                            <td>@device.Name</td>
                            <td>@device.Ip</td>
                            <td>@device.Type</td>
                            <td>
                                <input type="number" 
                                       class="form-control form-control-sm" 
                                       style="max-width: 150px;"
                                       min="5" 
                                       max="3600" 
                                       @bind="device.PingFrequencySeconds" 
                                       @bind:event="oninput" />
                                <small class="text-muted">Min: 5s, Max: 1hr</small>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-primary" 
                                        @onclick="() => SaveDevice(device)"
                                        disabled="@(savingDeviceId == device.Id)">
                                    @if (savingDeviceId == device.Id)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status"></span>
                                        <span>Saving...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-save"></i>
                                        <span>Save</span>
                                    }
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show mt-3" role="alert">
                @statusMessage
                <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
            </div>
        }
    }
</div>

@code {
    private List<Device>? devices;
    private bool isLoading = true;
    private Guid? savingDeviceId = null;
    private string? statusMessage;
    private bool isError = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadDevices();
    }

    private async Task LoadDevices()
    {
        try
        {
            isLoading = true;
            devices = await deviceApiClient.GetDevices();
        }
        catch (Exception ex)
        {
            statusMessage = $"Error loading devices: {ex.Message}";
            isError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveDevice(Device device)
    {
        try
        {
            // Validate ping frequency
            if (device.PingFrequencySeconds < 5)
            {
                device.PingFrequencySeconds = 5;
            }
            else if (device.PingFrequencySeconds > 3600)
            {
                device.PingFrequencySeconds = 3600;
            }

            savingDeviceId = device.Id;
            statusMessage = null;
            
            await deviceApiClient.UpdateDevice(device);
            
            statusMessage = $"Successfully updated ping frequency for {device.Name} to {device.PingFrequencySeconds} seconds";
            isError = false;
        }
        catch (Exception ex)
        {
            statusMessage = $"Error saving device: {ex.Message}";
            isError = true;
        }
        finally
        {
            savingDeviceId = null;
        }
    }
}
