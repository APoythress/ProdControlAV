@page "/devicemanager"
@using System.Net.Http
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@using ProdControlAV.Core.Models
@inject HttpClient Http

<div class="container-sm mt-5 text-white">
    <EditForm Model="@_device" OnValidSubmit="@HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row">
            <div class="col-9 col-sm-6">
                <label class="form-label">Device Name</label>
                <InputText class="form-control" @bind-Value="_device.Name" />
                <div class="form-text">Give your device a name</div>
            </div>
            <div class="col-9 col-sm-6">
                <label class="form-label">Device Model</label>
                <InputText class="form-control" @bind-Value="_device.Model" />
                <div class="form-text">Input the model of your device</div>
            </div>
        </div>

        <div class="row">
            <div class="col-9 col-sm-6">
                <label class="form-label">Device Brand</label>
                <InputText class="form-control" @bind-Value="_device.Brand" />
                <div class="form-text">What brand is your device?</div>
            </div>
            <div class="col-9 col-sm-6">
                <label class="form-label">Device Type</label>
                <InputText class="form-control" @bind-Value="_device.Type" />
                <div class="form-text">Audio, Video, Lighting, Network or Other?</div>
            </div>
        </div>

        <div class="row mt-2">
            <div class="col-9 col-sm-6">
                <label class="form-label">Device Ip</label>
                <InputText class="form-control" @bind-Value="_device.Ip" />
                <div class="form-text">What brand is your device?</div>
            </div>
            <div class="col">
                <div class="form-check form-switch">
                    <InputCheckbox class="form-check-input" @bind-Value="_device.AllowTelNet"/>
                    <label class="form-check-label">Allow TelNet Commands?</label>
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary mt-3" disabled="@_isSubmitting">
            @(_isSubmitting ? "Adding..." : "Add Device")
        </button>

        @if (!string.IsNullOrEmpty(_statusMessage))
        {
            <div class="mt-3">@_statusMessage</div>
        }
    </EditForm>
</div>

@code {
    private Device _device = new();
    private bool _isSubmitting;
    private string? _statusMessage;

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/devices", _device);
            if (response.IsSuccessStatusCode)
            {
                _statusMessage = "Device added successfully!";
                _device = new Device(); // Reset the form
            }
            else
            {
                _statusMessage = $"Error: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
