@page "/devicemanager"
@using System.Net.Http
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@using ProdControlAV.Core.Models
@inject HttpClient Http

<div class="container-sm mt-5">
    <EditForm Model="@_device" OnValidSubmit="@HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row">
            <div class="col-9 col-sm-6">
                <label class="form-label">Device Name</label>
                <InputText class="form-control" @bind-Value="_device.Name" />
                <div class="form-text">Give your device a name</div>
            </div>
            <div class="col-9 col-sm-6">
                <label class="form-label">Device Model</label>
                <InputText class="form-control" @bind-Value="_device.Model" />
                <div class="form-text">Input the model of your device</div>
            </div>
        </div>

        <div class="row">
            <div class="col-9 col-sm-6">
                <label class="form-label">Device Brand</label>
                <InputText class="form-control" @bind-Value="_device.Brand" />
                <div class="form-text">What brand is your device?</div>
            </div>
            <div class="col-9 col-sm-6">
                <label class="form-label">Device Type</label>
                <InputSelect class="form-select" @bind-Value="_device.Type">
                    <option value="">-- Select Type --</option>
                    <option value="Audio">Audio</option>
                    <option value="Switcher">Video Switcher</option>
                    <option Value="Camera">Camera</option>
                    <option value="Lighting">Lighting</option>
                    <option value="Network">Network</option>
                    <option value="Other">Other</option>
                </InputSelect>
                <div class="form-text">Select the device type</div>
            </div>
        </div>

        <div class="row mt-2">
            <!-- Device IP -->
            <div class="col-9 col-sm-6">
                <label class="form-label">Device Ip</label>
                <InputText class="form-control" @bind-Value="_device.Ip"/>
                <div class="form-text">Enter the IP address of the device</div>
            </div>
            <!-- Device Port -->
            <div class="col-9 col-sm-6">
                <label class="form-label">Port (Optional)</label>
                <InputNumber class="form-control" @bind-Value="_device.Port"/>
                <div class="form-text">Default is 80 if not specified</div>
            </div>
        </div>

        <div class="row mt-2">
            <div class="col">
                <div class="form-check form-switch">
                    <InputCheckbox class="form-check-input" @bind-Value="_device.AllowTelNet"/>
                    <label class="form-check-label">Allow TelNet Commands?</label>
                </div>
            </div>
        </div>

        <!-- ATEM Configuration Section -->
        @if (_device.Type == "ATEM" || _device.Type == "Video")
        {
            <div class="row mt-3">
                <div class="col-12">
                    <h5 class="border-bottom pb-2">ATEM Configuration</h5>
                </div>
            </div>

            <div class="row mt-2">
                <div class="col">
                    <div class="form-check form-switch">
                        <input type="checkbox" class="form-check-input" id="atemEnabled" checked="@(_device.AtemEnabled ?? false)" @onchange="@((ChangeEventArgs e) => _device.AtemEnabled = (bool)e.Value!)"/>
                        <label class="form-check-label" for="atemEnabled">Enable ATEM Control</label>
                        <div class="form-text">Enable remote control of this ATEM video switcher</div>
                    </div>
                </div>
            </div>

            @if (_device.AtemEnabled == true)
            {
                <div class="row mt-2">
                    <div class="col-9 col-sm-6">
                        <label class="form-label">Default Transition Type</label>
                        <InputSelect class="form-select" @bind-Value="_device.AtemTransitionDefaultType">
                            <option value="">-- Select Type --</option>
                            <option value="mix">Mix (Fade)</option>
                            <option value="cut">Cut</option>
                        </InputSelect>
                        <div class="form-text">Default transition style for program switching</div>
                    </div>
                    <div class="col-9 col-sm-6">
                        <label class="form-label">Default Transition Rate (frames)</label>
                        <InputNumber class="form-control" @bind-Value="_device.AtemTransitionDefaultRate" min="1" max="250"/>
                        <div class="form-text">Transition duration in frames (e.g., 30 frames ~= 1 second at 30fps)</div>
                    </div>
                </div>
            }
        }

        <button type="submit" class="btn btn-primary mt-3" disabled="@_isSubmitting">
            @(_isSubmitting ? "Adding..." : "Add Device")
        </button>

        @if (!string.IsNullOrEmpty(_statusMessage))
        {
            <div class="mt-3">@_statusMessage</div>
        }
    </EditForm>
</div>

@code {
    private Device _device = new();
    private bool _isSubmitting;
    private string? _statusMessage;

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/devices", _device);
            if (response.IsSuccessStatusCode)
            {
                _statusMessage = "Device added successfully!";
                _device = new Device(); // Reset the form
            }
            else
            {
                _statusMessage = $"Error: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
