@page "/signup"
@using System.ComponentModel.DataAnnotations
@using System.Net.Http
@using System.Net.Http.Json
@inject NavigationManager Nav
@inject HttpClient Http
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Mvc

<PageTitle>Sign Up</PageTitle>

<div class="modal modal-sheet position-static d-block bg-body-secondary p-4 py-md-5">
    <div class="modal-dialog">
        <div class="modal-content rounded-4 shadow">
            <div class="modal-body p-5">
                <div class="row align-items-center">
                    <h3 class="mb-3">Create your account</h3>
                    <hr class="my-4">
                    
                    <EditForm Model="@Model" OnValidSubmit="@SubmitAsync">
                        <DataAnnotationsValidator/>
                        <ValidationSummary/>

                        <div class="form-group mb-3">
                            <label for="email">Email</label>
                            <InputText id="email" class="form-control" @bind-Value="Model.Email" placeholder="name@domain.com"/>
                        </div>

                        <div class="form-group mb-3">
                            <label for="password">Password</label>
                            <InputText id="password" type="password" class="form-control" @bind-Value="Model.Password"/>
                        </div>

                        <div class="form-group mb-3">
                            <label for="confirm">Confirm Password</label>
                            <InputText id="confirm" type="password" class="form-control" @bind-Value="Model.ConfirmPassword"/>
                        </div>

                        <div class="form-group mb-3">
                            <label for="displayName">Display Name (optional)</label>
                            <InputText id="displayName" class="form-control" @bind-Value="Model.DisplayName"/>
                        </div>

                        <fieldset class="mb-3">
                            <div class="form-group mt-2">
                                <label for="joinCode">Group Invite Code (required)</label>
                                <InputText id="joinCode" class="form-control" @bind-Value="Model.JoinCode" placeholder="group code" required/>
                            </div>
                        </fieldset>
                        
                        <hr class="my-4">

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Create Account</button>
                            <a class="btn btn-link" href="/signin">Already have an account?</a>
                        </div>
                    </EditForm>
                    
                    <hr class="my-4">
                    
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <p class="alert alert-danger mt-3 text-center" role="alert">@errorMessage</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>



@code {
    private SignUpRequest Model = new();
    private string errorMessage = string.Empty;

    private async Task SubmitAsync()
    {
        // IMPORTANT: rooted relative URL for same-origin HTTPS
        var resp = await Http.PostAsJsonAsync("/api/auth/register", new
        {
            email = Model.Email,
            password = Model.Password,
            confirmPassword = Model.ConfirmPassword,
            displayName = Model.DisplayName,
            joinCode = Model.JoinCode
        });

        if (resp.IsSuccessStatusCode) Nav.NavigateTo("/"); // back to SignIn screen
        else
        {

            errorMessage = await resp.Content.ReadAsStringAsync();
            StateHasChanged();
        }
        // TODO: show API errors via ValidationSummary
    }

    public class SignUpRequest
    {
        [Required, EmailAddress] public string Email { get; set; } = string.Empty;
        [Required, MinLength(8)] public string Password { get; set; } = string.Empty;
        [Compare(nameof(Password))] public string ConfirmPassword { get; set; } = string.Empty;
        public string? DisplayName { get; set; }
        public string JoinCode { get; set; }
    }
    public enum TenantSelectionMode { Create, Join }
}
