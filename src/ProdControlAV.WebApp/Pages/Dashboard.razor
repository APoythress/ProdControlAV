@page "/Dashboard"
@using System.Net.Http
@using System.Net.Http.Json
@using System.Threading
@using ProdControlAV.Core.Models
@using ProdControlAV.WebApp.Components

@implements IAsyncDisposable

@inject HttpClient Http
@inject IJSRuntime JsRuntime

<div class="container mt-5 text-white">
    <!-- =============== Devices =============== -->
    <!-- Device Header -->
    <h3 class="text-center mb-4"><u>Device Status</u></h3>

    <!-- Device Cards -->
    <div class="row g-3 justify-content-center">
        @{
            if (_devices != null)
                foreach (var device in _devices)
                {
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <div class="card text-center bg-dark border-light text-white" style="cursor: pointer;"
                             @onclick="@(() => OpenDeviceModal(device))">
                            <div class="card-body">
                                <h5 class="card-title">@device.Name</h5>
                                <br/>
                                <p class="card-text">
                                    Status:
                                    <span class="badge @GetStatusClass(device)">@(device.Status ? "online" : "offline")</span>
                                </p>
                            </div>

                        </div>
                    </div>
                }
        }
    </div>

    <!-- Device Modal -->
    <div class="modal fade" id="deviceModal" tabindex="-1" aria-labelledby="deviceModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark text-white">
                <div class="modal-header">
                    <h5 class="modal-title" id="deviceModalLabel">Device: @(_selectedDevice?.Name ?? "")</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (_selectedDevice != null)
                    {
                        <!-- Device Details Section -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h6 class="mb-3"><u>Device Details</u></h6>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="deviceName" class="form-label">Name</label>
                                <input type="text" class="form-control" id="deviceName" @bind="_deviceForm.Name">
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="deviceIp" class="form-label">IP Address</label>
                                <input type="text" class="form-control" id="deviceIp" @bind="_deviceForm.Ip">
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="deviceModel" class="form-label">Model</label>
                                <input type="text" class="form-control" id="deviceModel" @bind="_deviceForm.Model" readonly>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label for="deviceStatus" class="form-label">Status</label>
                                <input type="text" class="form-control" id="deviceStatus" value="@(_selectedDevice.Status ? "Online" : "Offline")" readonly>
                            </div>

                            <div class="col-12 mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="allowTelnet" @bind="_deviceForm.AllowTelNet">
                                    <label class="form-check-label" for="allowTelnet">
                                        Allow Telnet
                                    </label>
                                </div>
                            </div>

                            <div class="col-12 mb-3">
                                <label for="deviceLocation" class="form-label">Location</label>
                                <input type="text" class="form-control" id="deviceLocation" @bind="_deviceForm.Location" placeholder="Enter device location (optional)">
                            </div>
                        </div>

                        <!-- Device Actions Section -->
                        <div class="row">
                            <div class="col-12">
                                <h6 class="mb-3"><u>Device Actions</u></h6>
                                @if (_deviceCommands.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-dark table-striped">
                                            <thead>
                                            <tr>
                                                <th>Action Name</th>
                                                <th>Execute</th>
                                            </tr>
                                            </thead>
                                            <tbody>
                                            @foreach (var command in _deviceCommands)
                                            {
                                                <tr>
                                                    <td>@command.CommandName</td>
                                                    <td>
                                                        <button class="btn btn-sm btn-outline-light"
                                                                @onclick="@(() => TriggerCommand(command.CommandId))"
                                                                disabled="@_isExecutingCommand">
                                                            @if (_isExecutingCommand)
                                                            {
                                                                <span class="spinner-border spinner-border-sm" role="status"></span>
                                                            }
                                                            else
                                                            {
                                                                <text>Execute</text>
                                                            }
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">No actions available for this device.</p>
                                }
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_modalMessage))
                    {
                        <div class="alert @_modalMessageCss mt-3" role="alert">
                            @_modalMessage
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success" @onclick="SaveDeviceChanges" disabled="@_isSaving">
                        @if (_isSaving)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            <text> Saving...</text>
                        }
                        else
                        {
                            <text>Save Changes</text>
                        }
                    </button>
                    <button type="button" class="btn btn-danger" @onclick="ShowDeleteConfirmation" disabled="@(_isSaving || _isDeleting)">
                        @if (_isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            <text> Deleting...</text>
                        }
                        else
                        {
                            <text>Delete Device</text>
                        }
                    </button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-outline-light" disabled>Manage Actions</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Device Confirmation Modal -->
    <div class="modal fade" id="deleteConfirmationModal" tabindex="-1" aria-labelledby="deleteConfirmationModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteConfirmationModalLabel">Confirm Delete</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete the device "<strong>@(_selectedDevice?.Name ?? "")</strong>"?</p>
                    <p class="text-warning"><i class="fas fa-exclamation-triangle"></i> This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteDevice" disabled="@_isDeleting">
                        @if (_isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            <text> Deleting...</text>
                        }
                        else
                        {
                            <text>Delete</text>
                        }
                    </button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- =============== Commands =============== -->
    <!-- Commands Header -->
    <h4 class="text-center mt-5"><u>Commands</u></h4>
    
    <!-- Commands Grid -->
    <div class="mt-3">
        <CommandsGrid 
            Commands="@_commandsList"
            Devices="@_devicesList"
            ShowFilters="true"
            ShowTriggerAction="true"
            ShowEditAction="false"
            ShowDeleteAction="false"
            OnCommandTriggered="@OnCommandTriggered" />
    </div>
    
    <!-- Device / Command Totals -->
    <div class="d-flex justify-content-center flex-wrap gap-3 mt-3">
        <p class="text-info">Devices loaded: @_devices?.Count()</p>
        <p class="text-info">Commands loaded: @_commandsList?.Count()</p>
    </div>

</div>

@code {
    // ========== Page Load ==========
    protected override async Task OnInitializedAsync()
    {
        try
        {
            _devices = await GetDevicesAsync() ?? new();
            _commands = await GetCommandsAcync() ?? new();
            UpdateCommandsAndDevicesLists();
        }
        finally
        {
            StateHasChanged();
        }
    }
    
    // ========== Devices ==========
    #region Devices
        // Fields and Properties
        private List<DashboardDeviceDto>? _devices = new();
        private DeviceForm _deviceForm = new();
        private DashboardDeviceDto? _selectedDevice;
        
        // Classes
        private class DeviceForm
        {
            public string Name { get; set; } = "";
            public string Model { get; set; } = "";
            public string Ip { get; set; } = "";
            public bool AllowTelNet { get; set; }
            public string Location { get; set; } = "";
        }
        
        // Get logic
        private Task<List<DashboardDeviceDto>?> GetDevicesAsync() =>
            Http.GetFromJsonAsync<List<DashboardDeviceDto>>("api/devices/devices");
        
        private static string GetStatusClass(DashboardDeviceDto d) =>
            Equals(d?.Status, true) ? "bg-success" : "bg-danger";

        // Modal logic
        private async Task OpenDeviceModal(DashboardDeviceDto device)
        {
            _selectedDevice = device;
            
            // Initialize form with device data
            _deviceForm = new DeviceForm
            {
                Name = device.Name,
                Model = device.Model,
                Ip = device.Ip,
                AllowTelNet = device.AllowTelNet,
                Location = device.Location ?? ""
            };
            
            // Get actions for this device
            try
            {
                var allActions = await GetCommandsAcync() ?? [];
                _deviceCommands = allActions.Where(a => a.DeviceId == device.Id).ToList();
            }
            catch (Exception ex)
            {
                _deviceCommands = [];
                _modalMessage = $"Error loading actions: {ex.Message}";
                _modalMessageCss = "alert-danger";
            }
            
            // Clear previous messages
            _modalMessage = null;
            StateHasChanged();
            
            // Show modal using JavaScript interop
            await ShowModal();
        }

        // DTO matching API response
        public class DashboardDeviceDto
        {
            public Guid Id { get; }
            public string Name { get; set; } = "";
            public string Model { get; } = "";
            public string Brand { get; } = "";
            public string Type { get; } = "";
            public bool AllowTelNet { get; set; }
            public string Ip { get; set; } = "";
            public int Port { get; }
            public string? Location { get; set; }
            public Guid TenantId { get; set; }
            public bool Status { get; }
        }

        private async Task SaveDeviceChanges()
        {
            if (_selectedDevice == null) return;

            _isSaving = true;
            _modalMessage = null;
            StateHasChanged();

            try
            {
                // Create UpsertDevice DTO for the API call
                var updateDto = new
                {
                    Id = _selectedDevice.Id,
                    Name = _deviceForm.Name,
                    Model = _deviceForm.Model,
                    Brand = _selectedDevice.Brand,
                    Type = _selectedDevice.Type,
                    AllowTelNet = _deviceForm.AllowTelNet,
                    Ip = _deviceForm.Ip,
                    Port = _selectedDevice.Port,
                    Location = _deviceForm.Location
                };

                var response = await Http.PutAsJsonAsync($"api/devices/{_selectedDevice.Id}", updateDto);
                
                if (response.IsSuccessStatusCode)
                {
                    // Update the device in our local list
                    var deviceIndex = _devices.FindIndex(d => d.Id == _selectedDevice.Id);
                    if (deviceIndex >= 0)
                    {
                        _devices[deviceIndex].Name = _deviceForm.Name;
                        _devices[deviceIndex].Ip = _deviceForm.Ip;
                        _devices[deviceIndex].AllowTelNet = _deviceForm.AllowTelNet;
                        _devices[deviceIndex].Location = _deviceForm.Location;
                    }

                    // Update selected device
                    _selectedDevice.Name = _deviceForm.Name;
                    _selectedDevice.Ip = _deviceForm.Ip;
                    _selectedDevice.AllowTelNet = _deviceForm.AllowTelNet;
                    _selectedDevice.Location = _deviceForm.Location;

                    _modalMessage = "Device updated successfully!";
                    _modalMessageCss = "alert-success";
                }
                else
                {
                    _modalMessage = $"Failed to update device: {response.ReasonPhrase}";
                    _modalMessageCss = "alert-danger";
                }
            }
            catch (Exception ex)
            {
                _modalMessage = $"Error updating device: {ex.Message}";
                _modalMessageCss = "alert-danger";
            }
            finally
            {
                _isSaving = false;
                StateHasChanged();
            }
        }
        
        private async Task ShowModal()
        {
            // Use JavaScript to show the Bootstrap modal
            try
            {
                await JsRuntime.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('deviceModal')).show()");
            }
            catch (Exception)
            {
                // Modal should still work with Bootstrap's built-in functionality if JS fails
            }
        }

        private async Task ShowDeleteConfirmation()
        {
            try
            {
                await JsRuntime.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('deleteConfirmationModal')).show()");
            }
            catch (Exception)
            {
                // Modal should still work with Bootstrap's built-in functionality if JS fails
            }
        }

        private async Task ConfirmDeleteDevice()
        {
        if (_selectedDevice == null) return;

        _isDeleting = true;
        StateHasChanged();

        try
        {
        var response = await Http.DeleteAsync($"api/devices/{_selectedDevice.Id}");

        if (response.IsSuccessStatusCode)
        {
        // Remove device from a local list
        _devices.RemoveAll(d => d.Id == _selectedDevice.Id);

        // Close both modals
        await JsRuntime.InvokeVoidAsync("eval", "bootstrap.Modal.getInstance(document.getElementById('deleteConfirmationModal')).hide()");
        await JsRuntime.InvokeVoidAsync("eval", "bootstrap.Modal.getInstance(document.getElementById('deviceModal')).hide()");

        // Reset selected device
        _selectedDevice = null;
        StateHasChanged();
        }
        else
        {
        _modalMessage = $"Failed to delete device: {response.ReasonPhrase}";
        _modalMessageCss = "alert-danger";

        // Close confirmation modal but keep device modal open to show the error
        await JsRuntime.InvokeVoidAsync("eval", "bootstrap.Modal.getInstance(document.getElementById('deleteConfirmationModal')).hide()");
        }
        }
        catch (Exception ex)
        {
        _modalMessage = $"Error deleting device: {ex.Message}";
        _modalMessageCss = "alert-danger";

        // Close confirmation modal but keep device modal open to show the error
        try
        {
        await JsRuntime.InvokeVoidAsync("eval", "bootstrap.Modal.getInstance(document.getElementById('deleteConfirmationModal')).hide()");
        }
        catch (Exception)
        {
        // Ignore JS errors
        }
        }
        finally
        {
        _isDeleting = false;
        StateHasChanged();
        }
        }
    
    #endregion
    
    // ========== Commands ==========
    #region Commands
        // Fields and Properties
        private List<DashboardDeviceCommandDto> _deviceCommands = new();
        private List<DashboardDeviceCommandDto>? _commands = new();   // now using DashboardDeviceActionDto from API
        private List<Command> _commandsList = new();   // For the CommandsGrid component
        private List<CommandsGrid.DeviceDto> _devicesList = new();  // For the CommandsGrid component
        
        private bool _isSaving;
        private bool _isDeleting;
        private bool _isExecutingCommand = false;
        private string? _modalMessage;
        private string _modalMessageCss = "alert-info";
        
        // Classes and DTO's
        public class DashboardDeviceCommandDto
        {
            public Guid CommandId { get; }
            public Guid TenantId { get; set; }
            public Guid DeviceId { get; }
            public string CommandName { get; set; } = "";
            public string? Description { get; set; }
            public string CommandType { get; set; } = "";
            public string? CommandData { get; set; }
            public string? HttpMethod { get; set; }
            public string? RequestBody { get; set; }
            public string? RequestHeaders { get; set; }
            public DateTimeOffset? CreatedUtc { get; set; }
            public DateTimeOffset? UpdatedUtc { get; set; }
            public bool RequireDeviceOnline { get; set; }
        }
        
        private class TriggerResponse
        {
            public bool success { get; set; }
            public string? message { get; set; }
            public Guid commandId { get; set; }
            public string? deviceName { get; set; }
        }
        
        // Get logic
        private Task<List<DashboardDeviceCommandDto>?> GetCommandsAcync() =>
            Http.GetFromJsonAsync<List<DashboardDeviceCommandDto>>("api/commands"); // <-- reads from Table Storage
        
        // Trigger Command (used in device modal)
        private async Task TriggerCommand(Guid commandId)
        {
            _isExecutingCommand = true;
            _modalMessage = null;
            StateHasChanged();

            try
            {
                var response = await Http.PostAsync($"api/commands/{commandId}/trigger", null);
                var result = await response.Content.ReadFromJsonAsync<TriggerResponse>();

                if (response.IsSuccessStatusCode && result?.success == true)
                {
                    _modalMessage = result.message ?? "Command queued successfully";
                    _modalMessageCss = "alert-success";
                }
                else
                {
                    _modalMessage = result?.message ?? $"Failed: {response.ReasonPhrase}";
                    _modalMessageCss = "alert-danger";
                }
            }
            catch (Exception ex)
            {
                _modalMessage = $"Error: {ex.Message}";
                _modalMessageCss = "alert-danger";
            }
            finally
            {
                _isExecutingCommand = false;
                StateHasChanged();
            }
        }
        
        // Convert DTOs for CommandsGrid component
        private void UpdateCommandsAndDevicesLists()
        {
            // Convert commands
            _commandsList = _commands?.Select(c => new Command
            {
                CommandId = c.CommandId,
                TenantId = c.TenantId,
                DeviceId = c.DeviceId,
                CommandName = c.CommandName,
                Description = c.Description,
                CommandType = c.CommandType,
                CommandData = c.CommandData,
                HttpMethod = c.HttpMethod,
                RequestBody = c.RequestBody,
                RequestHeaders = c.RequestHeaders,
                CreatedUtc = c.CreatedUtc ?? DateTimeOffset.UtcNow,
                UpdatedUtc = c.UpdatedUtc,
                RequireDeviceOnline = c.RequireDeviceOnline
            }).ToList() ?? new();
            
            // Convert devices
            _devicesList = _devices?.Select(d => new CommandsGrid.DeviceDto
            {
                Id = d.Id,
                Name = d.Name,
                Ip = d.Ip,
                Port = d.Port
            }).ToList() ?? new();
        }
        
        // Callback for when a command is triggered
        private Task OnCommandTriggered()
        {
            // Refresh data or perform any needed updates
            return Task.CompletedTask;
        }
    
    #endregion
    
    // ========== Page Refresh Loop ==========
    #region Page Loop
        // Fields and Properties
        private CancellationTokenSource? _refreshCts;
        private Task? _refreshTask;
        
        // Refresh loop
        private async Task RefreshLoopAsync(CancellationToken ct)
        {
            var timer = new PeriodicTimer(TimeSpan.FromSeconds(15));
            try
            {
                while (await timer.WaitForNextTickAsync(ct))
                {
                    try
                    {
                        var updatedDevices = await GetDevicesAsync() ?? [];
                        var updatedActions = await GetCommandsAcync() ?? [];
                        
                        _devices = updatedDevices.ToList();
                        _commands = updatedActions.ToList();
                        UpdateCommandsAndDevicesLists();

                        await InvokeAsync(StateHasChanged);
                    }
                    catch (Exception ex)
                    {
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }
            catch (OperationCanceledException)
            {
            }
            finally
            {
                timer.Dispose();
            }
        }
        
        protected override Task OnAfterRenderAsync(bool firstRender)
        {
            if (firstRender)
            {
                _refreshCts = new CancellationTokenSource();
                _refreshTask = RefreshLoopAsync(_refreshCts.Token); // fire-and-forget loop
            }

            return Task.CompletedTask;
        }

        public async ValueTask DisposeAsync()
        {
            if (_refreshCts is not null)
            {
                _refreshCts.Cancel();
                _refreshCts.Dispose();
            }

            if (_refreshTask is not null)
            {
                try { await _refreshTask; }
                catch (OperationCanceledException) { }
            }
        }
    #endregion
}