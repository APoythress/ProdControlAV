@page "/Dashboard"
@using System.Diagnostics
@using System.Net.Http
@using System.Net.Http.Json
@using System.Threading
@using ProdControlAV.Core.Models

@implements IAsyncDisposable

@inject HttpClient Http
@inject DeviceApiClient deviceApiClient

<div class="container mt-5 text-white">
    <h3 class="text-center mb-4"><u>Device Status</u></h3>
    
    <div class="row g-3 justify-content-center">
        @foreach (var device in Devices)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card text-center bg-dark border-light text-white h-100">
                    <div class="card-body">
                        <h5 class="card-title">@device.Name</h5>
                        <p class="card-text">
                            Status:
                            <span class="badge @GetStatusClass(device)">@device.Status</span>
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>

    <h4 class="text-center mt-5"><u>Actions</u></h4>

    <div class="d-flex justify-content-center flex-wrap gap-3 mt-3">
        @foreach (var action in Actions)
        {
            <button class="btn btn-outline-light"
                    @onclick="@(() => ExecuteDeviceCommandAsync(action.ActionId))">
                @action.ActionName
            </button>
        }
    </div>
    
    <div class="d-flex justify-content-center flex-wrap gap-3 mt-3">
        <p class="text-info">Devices loaded: @Devices?.Count()</p>
        <p class="text-info">Actions loaded: @Actions?.Count()</p>
    </div>
    
    <!-- Bind a toast element per action sent as a status notification -->
    @foreach (var actionStatus in Actions)
    {
        <div class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <img src="..." class="rounded me-2" alt="...">
                <strong class="me-auto">Bootstrap</strong>
                <small class="text-body-secondary">11 mins ago</small>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">
                Hello, world! This is a toast message.
            </div>
        </div>
    }
    

</div>

@code {
    private List<DeviceAction> Actions = new();   // initialized to avoid null on first render
    private List<Device> Devices = new();         // already safe
    private bool _loading = true;
    private bool loaded;
    private string? loadError;
    private string? _error;
    private CancellationTokenSource? _refreshCts;
    private Task? _refreshTask;
    
    private Task<List<Device>> GetDevicesAsync() =>
        Http.GetFromJsonAsync<List<Device>>("api/devices/devices"); // <-- correct route

    private Task<List<DeviceAction>> GetActionsAcync() =>
        Http.GetFromJsonAsync<List<DeviceAction>>("api/devices/actions");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Devices = await GetDevicesAsync() ?? new();
            Actions = await GetActionsAcync() ?? new();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            loaded = true;
            StateHasChanged();
        }
    }

    private sealed class DeviceDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string Ip { get; set; } = "";
        public int? Port { get; set; }
    }
    
    Guid selectedCommandId = Guid.Empty;

    string? ExecMessage = String.Empty;
    string ExecCss = "alert-info";

    private async Task ExecuteDeviceCommandAsync(Guid commandId)
    {
        ExecMessage = null;
        ExecCss = "alert-info";

        try
        {
            var resp = await Http.PostAsync($"api/commands/execute/{commandId}", content: null);
            var payload = await resp.Content.ReadFromJsonAsync<CommandExecResponse>();

            if (resp.IsSuccessStatusCode && payload is { success: true })
            {
                ExecCss = "alert-success";
                ExecMessage = $"✅ {payload.message} (HTTP {(payload.statusCode ?? 200)})";
            }
            else
            {
                ExecCss = "alert-danger";
                ExecMessage = $"❌ {payload?.message ?? "Failed"} (HTTP {(payload?.statusCode?.ToString() ?? resp.StatusCode.ToString())})";
            }
        }
        catch (Exception ex)
        {
            ExecCss = "alert-danger";
            ExecMessage = $"❌ Error: {ex.Message}";
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _refreshCts = new CancellationTokenSource();
            _refreshTask = RefreshLoopAsync(_refreshCts.Token); // fire-and-forget loop
        }

        return Task.CompletedTask;
    }
    
    private sealed class CommandExecResponse
    {
        public bool success { get; set; }
        public string? message { get; set; }
        public int? statusCode { get; set; }
        public string? response { get; set; }
    }

    private async Task RefreshLoopAsync(CancellationToken ct)
    {
        var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                try
                {
                    var updatedDevices = await GetDevicesAsync() ?? [];
                    var updatedActions = await GetActionsAcync() ?? [];
                    
                    Devices = updatedDevices.ToList();
                    Actions = updatedActions.ToList();

                    await InvokeAsync(StateHasChanged);
                }
                catch (Exception ex)
                {
                    _error = ex.Message;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            timer.Dispose();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_refreshCts is not null)
        {
            _refreshCts.Cancel();
            _refreshCts.Dispose();
        }

        if (_refreshTask is not null)
        {
            try { await _refreshTask; }
            catch (OperationCanceledException) { }
        }
    }

    private static string GetStatusClass(Device d) =>
        Equals(d?.Status, true) ? "bg-success" : "bg-danger";
}