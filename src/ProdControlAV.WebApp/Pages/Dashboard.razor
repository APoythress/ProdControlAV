@page "/Dashboard"
@using System.Diagnostics
@using System.Net.Http
@using System.Net.Http.Json
@using System.Threading
@using ProdControlAV.Core.Models

@implements IAsyncDisposable

@inject HttpClient Http
@inject DeviceApiClient deviceApiClient
@inject IJSRuntime JSRuntime

<div class="container mt-5 text-white">
    <h3 class="text-center mb-4"><u>Device Status</u></h3>
    
    <div class="row g-3 justify-content-center">
        @foreach (var device in Devices)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card text-center bg-dark border-light text-white" style="cursor: pointer;"
                     @onclick="@(() => OpenDeviceModal(device))">
                    <div class="card-body">
                        <h5 class="card-title">@device.Name</h5>
                        <br/>
                        <p class="card-text">
                            Status:
                            <span class="badge @GetStatusClass(device)">@(device.Status ? "online" : "offline")</span>
                        </p>
                    </div>

                </div>
            </div>
        }
    </div>

    <!-- Device Modal -->
    <div class="modal fade" id="deviceModal" tabindex="-1" aria-labelledby="deviceModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark text-white">
                <div class="modal-header">
                    <h5 class="modal-title" id="deviceModalLabel">Device: @(selectedDevice?.Name ?? "")</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (selectedDevice != null)
                    {
                        <!-- Device Details Section -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h6 class="mb-3"><u>Device Details</u></h6>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label for="deviceName" class="form-label">Name</label>
                                <input type="text" class="form-control" id="deviceName" @bind="deviceForm.Name">
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label for="deviceIp" class="form-label">IP Address</label>
                                <input type="text" class="form-control" id="deviceIp" @bind="deviceForm.Ip">
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label for="deviceModel" class="form-label">Model</label>
                                <input type="text" class="form-control" id="deviceModel" @bind="deviceForm.Model" readonly>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label for="deviceStatus" class="form-label">Status</label>
                                <input type="text" class="form-control" id="deviceStatus" value="@(selectedDevice.Status ? "Online" : "Offline")" readonly>
                            </div>
                            
                            <div class="col-12 mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="allowTelnet" @bind="deviceForm.AllowTelNet">
                                    <label class="form-check-label" for="allowTelnet">
                                        Allow Telnet
                                    </label>
                                </div>
                            </div>
                            
                            <div class="col-12 mb-3">
                                <label for="deviceLocation" class="form-label">Location</label>
                                <input type="text" class="form-control" id="deviceLocation" @bind="deviceForm.Location" placeholder="Enter device location (optional)">
                            </div>
                        </div>

                        <!-- Device Actions Section -->
                        <div class="row">
                            <div class="col-12">
                                <h6 class="mb-3"><u>Device Actions</u></h6>
                                @if (deviceActions.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-dark table-striped">
                                            <thead>
                                                <tr>
                                                    <th>Action Name</th>
                                                    <th>Execute</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var action in deviceActions)
                                                {
                                                    <tr>
                                                        <td>@action.ActionName</td>
                                                        <td>
                                                            <button class="btn btn-sm btn-outline-light" 
                                                                    @onclick="@(() => ExecuteDeviceCommandAsync(action.ActionId))"
                                                                    disabled="@isExecutingCommand">
                                                                @if (isExecutingCommand)
                                                                {
                                                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                                                }
                                                                else
                                                                {
                                                                    <text>Execute</text>
                                                                }
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">No actions available for this device.</p>
                                }
                            </div>
                        </div>
                    }
                    
                    @if (!string.IsNullOrEmpty(modalMessage))
                    {
                        <div class="alert @modalMessageCss mt-3" role="alert">
                            @modalMessage
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-success" @onclick="SaveDeviceChanges" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            <text> Saving...</text>
                        }
                        else
                        {
                            <text>Save Changes</text>
                        }
                    </button>
                    <button type="button" class="btn btn-danger" @onclick="ShowDeleteConfirmation" disabled="@(isSaving || isDeleting)">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            <text> Deleting...</text>
                        }
                        else
                        {
                            <text>Delete Device</text>
                        }
                    </button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-outline-light" disabled>Manage Actions</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteConfirmationModal" tabindex="-1" aria-labelledby="deleteConfirmationModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteConfirmationModalLabel">Confirm Delete</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete the device "<strong>@(selectedDevice?.Name ?? "")</strong>"?</p>
                    <p class="text-warning"><i class="fas fa-exclamation-triangle"></i> This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteDevice" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            <text> Deleting...</text>
                        }
                        else
                        {
                            <text>Delete</text>
                        }
                    </button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <h4 class="text-center mt-5"><u>Actions</u></h4>

    <div class="d-flex justify-content-center flex-wrap gap-3 mt-3">
        @foreach (var action in Actions)
        {
            <button class="btn btn-outline-light"
                    @onclick="@(() => ExecuteDeviceCommandAsync(action.ActionId))">
                @action.ActionName
            </button>
        }
    </div>
    
    <div class="d-flex justify-content-center flex-wrap gap-3 mt-3">
        <p class="text-info">Devices loaded: @Devices?.Count()</p>
        <p class="text-info">Actions loaded: @Actions?.Count()</p>
    </div>
    
    <!-- Bind a toast element per action sent as a status notification -->
    @foreach (var actionStatus in Actions)
    {
        <div class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <img src="..." class="rounded me-2" alt="...">
                <strong class="me-auto">Bootstrap</strong>
                <small class="text-body-secondary">11 mins ago</small>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">
                Hello, world! This is a toast message.
            </div>
        </div>
    }
    

</div>

@code {
    private List<DeviceAction> Actions = new();   // initialized to avoid null on first render
    private List<Device> Devices = new();         // already safe
    private bool _loading = true;
    private bool loaded;
    private string? loadError;
    private string? _error;
    private CancellationTokenSource? _refreshCts;
    private Task? _refreshTask;
    
    private Task<List<Device>> GetDevicesAsync() =>
        Http.GetFromJsonAsync<List<Device>>("api/devices/devices"); // <-- correct route

    private Task<List<DeviceAction>> GetActionsAcync() =>
        Http.GetFromJsonAsync<List<DeviceAction>>("api/devices/actions");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Devices = await GetDevicesAsync() ?? new();
            Actions = await GetActionsAcync() ?? new();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            loaded = true;
            StateHasChanged();
        }
    }

    private sealed class DeviceDto
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = "";
        public string Ip { get; set; } = "";
        public int? Port { get; set; }
    }
    
    Guid selectedCommandId = Guid.Empty;

    string? ExecMessage = String.Empty;
    string ExecCss = "alert-info";

    private async Task ExecuteDeviceCommandAsync(Guid commandId)
    {
        ExecMessage = null;
        ExecCss = "alert-info";

        try
        {
            var resp = await Http.PostAsync($"api/commands/execute/{commandId}", content: null);
            var payload = await resp.Content.ReadFromJsonAsync<CommandExecResponse>();

            if (resp.IsSuccessStatusCode && payload is { success: true })
            {
                ExecCss = "alert-success";
                ExecMessage = $"✅ {payload.message} (HTTP {(payload.statusCode ?? 200)})";
            }
            else
            {
                ExecCss = "alert-danger";
                ExecMessage = $"❌ {payload?.message ?? "Failed"} (HTTP {(payload?.statusCode?.ToString() ?? resp.StatusCode.ToString())})";
            }
        }
        catch (Exception ex)
        {
            ExecCss = "alert-danger";
            ExecMessage = $"❌ Error: {ex.Message}";
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _refreshCts = new CancellationTokenSource();
            _refreshTask = RefreshLoopAsync(_refreshCts.Token); // fire-and-forget loop
        }

        return Task.CompletedTask;
    }
    
    private sealed class CommandExecResponse
    {
        public bool success { get; set; }
        public string? message { get; set; }
        public int? statusCode { get; set; }
        public string? response { get; set; }
    }

    private async Task RefreshLoopAsync(CancellationToken ct)
    {
        var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                try
                {
                    var updatedDevices = await GetDevicesAsync() ?? [];
                    var updatedActions = await GetActionsAcync() ?? [];
                    
                    Devices = updatedDevices.ToList();
                    Actions = updatedActions.ToList();

                    await InvokeAsync(StateHasChanged);
                }
                catch (Exception ex)
                {
                    _error = ex.Message;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            timer.Dispose();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_refreshCts is not null)
        {
            _refreshCts.Cancel();
            _refreshCts.Dispose();
        }

        if (_refreshTask is not null)
        {
            try { await _refreshTask; }
            catch (OperationCanceledException) { }
        }
    }

    // Modal-related fields and methods
    private Device? selectedDevice;
    private DeviceForm deviceForm = new();
    private List<DeviceAction> deviceActions = new();
    private bool isSaving = false;
    private bool isDeleting = false;
    private bool isExecutingCommand = false;
    private string? modalMessage;
    private string modalMessageCss = "alert-info";

    private class DeviceForm
    {
        public string Name { get; set; } = "";
        public string Model { get; set; } = "";
        public string Ip { get; set; } = "";
        public bool AllowTelNet { get; set; }
        public string Location { get; set; } = "";
    }

    private async Task OpenDeviceModal(Device device)
    {
        selectedDevice = device;
        
        // Initialize form with device data
        deviceForm = new DeviceForm
        {
            Name = device.Name,
            Model = device.Model,
            Ip = device.Ip,
            AllowTelNet = device.AllowTelNet,
            Location = device.Location ?? ""
        };
        
        // Get actions for this device
        try
        {
            var allActions = await GetActionsAcync() ?? [];
            deviceActions = allActions.Where(a => a.DeviceId == device.Id).ToList();
        }
        catch (Exception ex)
        {
            deviceActions = [];
            modalMessage = $"Error loading actions: {ex.Message}";
            modalMessageCss = "alert-danger";
        }
        
        // Clear previous messages
        modalMessage = null;
        StateHasChanged();
        
        // Show modal using JavaScript interop
        await ShowModal();
    }

    private async Task SaveDeviceChanges()
    {
        if (selectedDevice == null) return;

        isSaving = true;
        modalMessage = null;
        StateHasChanged();

        try
        {
            // Create UpsertDevice DTO for the API call
            var updateDto = new
            {
                Id = selectedDevice.Id,
                Name = deviceForm.Name,
                Model = deviceForm.Model,
                Brand = selectedDevice.Brand,
                Type = selectedDevice.Type,
                AllowTelNet = deviceForm.AllowTelNet,
                Ip = deviceForm.Ip,
                Port = selectedDevice.Port,
                Location = deviceForm.Location
            };

            var response = await Http.PutAsJsonAsync($"api/devices/{selectedDevice.Id}", updateDto);
            
            if (response.IsSuccessStatusCode)
            {
                // Update the device in our local list
                var deviceIndex = Devices.FindIndex(d => d.Id == selectedDevice.Id);
                if (deviceIndex >= 0)
                {
                    Devices[deviceIndex].Name = deviceForm.Name;
                    Devices[deviceIndex].Ip = deviceForm.Ip;
                    Devices[deviceIndex].AllowTelNet = deviceForm.AllowTelNet;
                    Devices[deviceIndex].Location = deviceForm.Location;
                }

                // Update selected device
                selectedDevice.Name = deviceForm.Name;
                selectedDevice.Ip = deviceForm.Ip;
                selectedDevice.AllowTelNet = deviceForm.AllowTelNet;
                selectedDevice.Location = deviceForm.Location;

                modalMessage = "Device updated successfully!";
                modalMessageCss = "alert-success";
            }
            else
            {
                modalMessage = $"Failed to update device: {response.ReasonPhrase}";
                modalMessageCss = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            modalMessage = $"Error updating device: {ex.Message}";
            modalMessageCss = "alert-danger";
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task ShowModal()
    {
        // Use JavaScript to show the Bootstrap modal
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('deviceModal')).show()");
        }
        catch (Exception)
        {
            // Modal should still work with Bootstrap's built-in functionality if JS fails
        }
    }

    private async Task ShowDeleteConfirmation()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "new bootstrap.Modal(document.getElementById('deleteConfirmationModal')).show()");
        }
        catch (Exception)
        {
            // Modal should still work with Bootstrap's built-in functionality if JS fails
        }
    }

    private async Task ConfirmDeleteDevice()
    {
        if (selectedDevice == null) return;

        isDeleting = true;
        StateHasChanged();

        try
        {
            var response = await Http.DeleteAsync($"api/devices/{selectedDevice.Id}");
            
            if (response.IsSuccessStatusCode)
            {
                // Remove device from local list
                Devices.RemoveAll(d => d.Id == selectedDevice.Id);
                
                // Close both modals
                await JSRuntime.InvokeVoidAsync("eval", "bootstrap.Modal.getInstance(document.getElementById('deleteConfirmationModal')).hide()");
                await JSRuntime.InvokeVoidAsync("eval", "bootstrap.Modal.getInstance(document.getElementById('deviceModal')).hide()");
                
                // Reset selected device
                selectedDevice = null;
                StateHasChanged();
            }
            else
            {
                modalMessage = $"Failed to delete device: {response.ReasonPhrase}";
                modalMessageCss = "alert-danger";
                
                // Close confirmation modal but keep device modal open to show the error
                await JSRuntime.InvokeVoidAsync("eval", "bootstrap.Modal.getInstance(document.getElementById('deleteConfirmationModal')).hide()");
            }
        }
        catch (Exception ex)
        {
            modalMessage = $"Error deleting device: {ex.Message}";
            modalMessageCss = "alert-danger";
            
            // Close confirmation modal but keep device modal open to show the error
            try
            {
                await JSRuntime.InvokeVoidAsync("eval", "bootstrap.Modal.getInstance(document.getElementById('deleteConfirmationModal')).hide()");
            }
            catch (Exception)
            {
                // Ignore JS errors
            }
        }
        finally
        {
            isDeleting = false;
            StateHasChanged();
        }
    }

    private static string GetStatusClass(Device d) =>
        Equals(d?.Status, true) ? "bg-success" : "bg-danger";
}