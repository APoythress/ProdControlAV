@page "/"
@layout NonHeaderLayout

@using System.ComponentModel.DataAnnotations
@using System.Net.Http
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms

@inject NavigationManager Nav
@inject HttpClient Http


<PageTitle>Sign In</PageTitle>

<div class="card accent-purple" style="margin: 15%">
    <div class="">
        <div class="">
            <div class="">
                <div class="row align-items-center">
                    <h3 class="fw-bold mb-3 text-center">Welcome!</h3>

                    <EditForm Model="@Model" OnValidSubmit="@SubmitAsync">
                        <DataAnnotationsValidator/>
                        <ValidationSummary/>

                        <div class="form-group mb-3">
                            <label for="email">Email</label>
                            <InputText id="email" class="form-control" @bind-Value="Model.Email"/>
                        </div>

                        <div class="form-group mb-3">
                            <label for="password">Password</label>
                            <InputText id="password" type="password" class="form-control" @bind-Value="Model.Password"/>
                        </div>

                        <div class="d-flex justify-content-center">
                            <button type="submit" class="btn btn-primary text-center" disabled="@isSubmitting">Sign in</button>
                        </div>
                        
                        @if (isSubmitting)
                        {
                            <p class="text-center mt-3">@statusMessage</p>
                        }
                        
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <p class="alert alert-danger mt-3 text-center" role="alert">@errorMessage</p>
                        }
                    </EditForm>
                    
                    <hr class="my-4">
                    
                    <a style="font-size: .75rem;" href="/SignUp">Create an Account</a>
                    
                </div>
            </div>
        </div>
    </div>
</div>


@code {
    private SignInRequest Model = new();
    private string errorMessage = String.Empty;
    private bool isSubmitting = false;
    private string statusMessage = String.Empty;
    private System.Threading.CancellationTokenSource? _cts;

    private async Task SubmitAsync()
    {
        isSubmitting = true;
        errorMessage = String.Empty;
        statusMessage = "signing you in";
        _cts = new System.Threading.CancellationTokenSource();
        
        // Start a timer to change the message after 5 seconds
        var timer = Task.Delay(5000, _cts.Token);
        
        try
        {
            var loginTask = Http.PostAsJsonAsync("/api/auth/login", Model);
            
            // Wait for either the login to complete or the timer to expire
            var completedTask = await Task.WhenAny(loginTask, timer);
            
            if (completedTask == timer && !_cts.Token.IsCancellationRequested)
            {
                // Timer expired first, update the message
                statusMessage = "waking up the computer overlords... hang tight";
                StateHasChanged();
                
                // Now wait for the login to complete
                var resp = await loginTask;
                await HandleLoginResponse(resp);
            }
            else
            {
                // Login completed before timer
                var resp = await loginTask;
                await HandleLoginResponse(resp);
            }
        }
        catch (Exception)
        {
            errorMessage = "An error occurred. Please try again.";
        }
        finally
        {
            _cts?.Cancel();
            _cts?.Dispose();
            isSubmitting = false;
            statusMessage = String.Empty;
            StateHasChanged();
        }
    }

    private async Task HandleLoginResponse(HttpResponseMessage resp)
    {
        if (resp.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/dashboard");
        }
        else
        {
            errorMessage = "invalid username or password";
        }
    }

    public class SignInRequest
    {
        [Required, EmailAddress] public string Email { get; set; } = string.Empty;
        [Required] public string Password { get; set; } = string.Empty;
    }
}