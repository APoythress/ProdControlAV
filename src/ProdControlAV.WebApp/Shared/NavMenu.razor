@inject IJSRuntime JSRuntime
@inject HttpClient Http
@using Microsoft.JSInterop
@using System.Net.Http
@using System.Net.Http.Json

<aside class="w-full md:w-64 bg-gray-900 text-white min-h-screen px-4 py-6">
    <nav class="navbar fixed-top">
      <div class="container-fluid">
        <span class="d-flex align-items-center">
          <i class="bi bi-person-circle" style="font-size: 2rem; padding:0 0.5rem;"></i>
          @displayName
        </span>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasDarkNavbar" aria-controls="offcanvasDarkNavbar" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasDarkNavbar" aria-labelledby="offcanvasDarkNavbarLabel">
          <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="offcanvasDarkNavbarLabel">Menu</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
          </div>
          <div class="offcanvas-body">
            <ul class="navbar-nav justify-content-end flex-grow-1 pe-3">
              <li class="nav-item" data-bs-dismiss="offcanvas">
                <a class="nav-link active" aria-current="page" href="/Dashboard">Home</a>
              </li>
              <li class="nav-item" data-bs-dismiss="offcanvas">
                  <a class="nav-link" href="/devicemanager">Add Device</a>
              </li>
              <li class="nav-item" data-bs-dismiss="offcanvas">
                  <a class="nav-link" href="/commands">Commands</a>
              </li>
              <li class="nav-item" data-bs-dismiss="offcanvas">
                  <a class="nav-link" href="/agent-health">Agent Health</a>
              </li>
              <li class="nav-item" data-bs-dismiss="offcanvas">
                  <a class="nav-link" href="/settings">Settings</a>
              </li>
              <li class="nav-item" data-bs-dismiss="offcanvas">
                  <button class="nav-link btn btn-link text-start w-100" @onclick="SignOut">
                      <i class="bi bi-box-arrow-right"></i> Sign Out
                  </button>
              </li>
            </ul>
          </div>
        </div>
      </div>
</nav>
</aside>

@code {
    private string displayName = "Loading...";
    private DateTime _lastActivity = DateTime.UtcNow;
    private System.Timers.Timer _inactivityTimer;
    private const int InactivityTimeoutMinutes = 15;

    protected override async Task OnInitializedAsync()
    {
        await LoadUserInfo();
        SetupInactivityTimer();
        RegisterActivityEvents();
        RegisterUnloadEvent();
    }

    private void SetupInactivityTimer()
    {
        _inactivityTimer = new System.Timers.Timer(60000); // check every minute
        _inactivityTimer.Elapsed += async (_, __) => await CheckInactivity();
        _inactivityTimer.Start();
    }

    private async Task CheckInactivity()
    {
        // Use static field for inactivity check
        if ((DateTime.UtcNow - _lastActivityStatic).TotalMinutes > InactivityTimeoutMinutes)
        {
            _inactivityTimer.Stop();
            await SignOut();
        }
    }

    private void RegisterActivityEvents()
    {
        JSRuntime.InvokeVoidAsync("eval", @"
            window.addEventListener('mousemove', () => DotNet.invokeMethodAsync('ProdControlAV.WebApp', 'ReportActivity'));
            window.addEventListener('keydown', () => DotNet.invokeMethodAsync('ProdControlAV.WebApp', 'ReportActivity'));
        ");
    }

    private void RegisterUnloadEvent()
    {
        JSRuntime.InvokeVoidAsync("eval", @"
            window.addEventListener('beforeunload', function() {
                DotNet.invokeMethodAsync('ProdControlAV.WebApp', 'SignOutOnUnload');
            });
        ");
    }

    [JSInvokable]
    public static void ReportActivity()
    {
        // Use a static field to track last activity
        _lastActivityStatic = DateTime.UtcNow;
    }

    [JSInvokable]
    public static void SignOutOnUnload()
    {
        // Optionally, you could call an API endpoint here to log out, but since browser unload is async,
        // this is best effort. Most secure apps rely on cookie expiration and server-side checks.
        // You may want to clear local storage or cookies here if needed.
    }

    private static DateTime _lastActivityStatic = DateTime.UtcNow;

    private async Task LoadUserInfo()
    {
        try
        {
            var userInfo = await Http.GetFromJsonAsync<UserInfoResponse>("api/auth/user");
            displayName = userInfo?.DisplayName ?? "User";
        }
        catch (Exception)
        {
            displayName = "User";
        }
        StateHasChanged();
    }

    private async Task SignOut()
    {
        displayName = "Signing out...";
        StateHasChanged();
        await Http.PostAsync("/api/auth/logout", content: null);
        await JSRuntime.InvokeVoidAsync("window.location.replace", "/");
    }

    private class UserInfoResponse
    {
        public string DisplayName { get; set; } = "";
        public string Email { get; set; } = "";
        public string UserId { get; set; } = "";
    }
}