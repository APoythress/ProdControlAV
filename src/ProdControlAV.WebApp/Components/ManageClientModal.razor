@using System.Net.Http
@using System.Net.Http.Json
@using ProdControlAV.WebApp.Components.Ui
@using Microsoft.JSInterop

@inject HttpClient Http
@inject IJSRuntime JsRuntime

<UiModal @bind-IsOpen="@IsOpen"
         Title="@($"Managing {TenantName}")"
         Size="lg"
         Variant="card-glow-blue">

    <ChildContent>
        @if (_loading)
        {
            <div class="text-center">
                <div class="spinner-border text-light" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (_error != null)
        {
            <div class="alert alert-danger">
                @_error
            </div>
        }
        else if (_managementData != null)
        {
            <UiCard Title="Client Details"
                    SubTitle="Basic information"
                    Variant="card pad card-muted">

                <div class="ui-grid cols-3">
                    <UiField Label="Client Name">
                        <input class="input" @bind="_managementData.Name" />
                    </UiField>

                    <UiField Label="Subscription Plan">
                        <select class="input" @bind="_selectedSubscriptionPlanId">
                            <option value="">-- Select Plan --</option>
                            @foreach (var plan in _subscriptionPlans)
                            {
                                <option value="@plan.SubscriptionPlanId">@plan.SubscriptionPlanText</option>
                            }
                        </select>
                    </UiField>

                    <UiField Label="Client Status">
                        <select class="input" @bind="_selectedStatusId">
                            <option value="">-- Select Status --</option>
                            @foreach (var status in _statuses)
                            {
                                <option value="@status.TenantStatusId">@status.TenantStatusText</option>
                            }
                        </select>
                    </UiField>
                </div>

                <div class="ui-grid cols-2 mt-3">
                    <UiButton Variant="btn btn-warning"
                              OnClick="@ShowGenerateSlugConfirmation">
                        Generate New Slug
                    </UiButton>

                    <UiButton Variant="btn btn-success"
                              OnClick="@ShowAddAgentModal">
                        Add New Agent
                    </UiButton>
                </div>
            </UiCard>

            <UiCard Title="Client Notes"
                    SubTitle="Add and view notes"
                    Variant="card pad accent-blue"
                    Class="mt-3">

                <UiField Label="Add New Note">
                    <textarea class="input" 
                              rows="4" 
                              maxlength="@_maxNoteCharacters"
                              @bind="_newNoteText"
                              placeholder="Enter note (max @_maxNoteCharacters characters)"></textarea>
                    <small class="muted">@(_newNoteText?.Length ?? 0) / @_maxNoteCharacters characters</small>
                </UiField>

                <UiButton Variant="btn btn-primary mt-2"
                          Disabled="@string.IsNullOrWhiteSpace(_newNoteText)"
                          OnClick="@AddNote">
                    Add Note
                </UiButton>

                @if (_managementData.RecentNotes.Any())
                {
                    <div class="notes-grid mt-4">
                        @foreach (var note in _managementData.RecentNotes)
                        {
                            <div class="note-item" title="@note.NoteText">
                                <div class="note-date">@note.CreatedUtc.ToString("MMM dd, yyyy hh:mm tt") UTC</div>
                                <div class="note-text">@GetTruncatedNoteText(note.NoteText)</div>
                            </div>
                        }
                    </div>

                    <UiButton Variant="btn btn-link mt-2"
                              OnClick="@NavigateToAllNotes">
                        See all notes
                    </UiButton>
                }
                else
                {
                    <div class="alert alert-info mt-3">
                        No notes available for this client.
                    </div>
                }
            </UiCard>
        }
    </ChildContent>

    <Footer>
        <UiButton Variant="btn btn-primary"
                  OnClick="@SaveChanges"
                  Disabled="@_saving">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm" role="status"></span>
                <span> Saving...</span>
            }
            else
            {
                <text>Save</text>
            }
        </UiButton>

        <UiButton Variant="btn btn-secondary"
                  OnClick="@Cancel">
            Cancel
        </UiButton>

        <UiButton Variant="btn btn-danger"
                  OnClick="@ShowDeleteConfirmation">
            Delete Client
        </UiButton>
    </Footer>
</UiModal>

<!-- Generate Slug Confirmation Modal -->
<UiModal @bind-IsOpen="_showSlugConfirmation"
         Title="Generate New Slug"
         Size="md"
         Variant="card-glow-orange">
    <ChildContent>
        <div class="alert alert-warning">
            <strong>⚠️ Warning:</strong> This action cannot be undone!
            <br />
            Generating a new slug will change the activation credentials for this client. 
            The client will need to reconfigure their agent with the new slug.
        </div>
        <p>Are you sure you want to continue?</p>
    </ChildContent>
    <Footer>
        <UiButton Variant="btn btn-warning" OnClick="@GenerateNewSlug">
            Yes, Generate New Slug
        </UiButton>
        <UiButton Variant="btn btn-secondary" OnClick="@(() => _showSlugConfirmation = false)">
            Cancel
        </UiButton>
    </Footer>
</UiModal>

<!-- Add Agent Modal -->
<UiModal @bind-IsOpen="_showAddAgentModal"
         Title="Add New Agent"
         Size="md"
         Variant="card-glow-green">
    <ChildContent>
        <UiField Label="Agent Name">
            <input class="input" @bind="_newAgentName" placeholder="Enter agent name" />
        </UiField>

        <UiField Label="Location Name (Optional)" Class="mt-3">
            <input class="input" @bind="_newAgentLocation" placeholder="e.g., Main Campus, Building A" />
        </UiField>
    </ChildContent>
    <Footer>
        <UiButton Variant="btn btn-success" 
                  OnClick="@AddAgent"
                  Disabled="@string.IsNullOrWhiteSpace(_newAgentName)">
            Add Agent
        </UiButton>
        <UiButton Variant="btn btn-secondary" OnClick="@(() => _showAddAgentModal = false)">
            Cancel
        </UiButton>
    </Footer>
</UiModal>

<!-- Delete Confirmation Modal -->
<UiModal @bind-IsOpen="_showDeleteConfirmation"
         Title="Delete Client"
         Size="md"
         Variant="card-glow-red">
    <ChildContent>
        <div class="alert alert-danger">
            <strong>⚠️ EXTREMELY DESTRUCTIVE:</strong> This action cannot be undone!
        </div>
        <p>Please type <strong>DELETE CLIENT</strong> to confirm:</p>
        <input class="input" @bind="_deleteConfirmText" placeholder="DELETE CLIENT" />
    </ChildContent>
    <Footer>
        <UiButton Variant="btn btn-danger" 
                  OnClick="@DeleteClient"
                  Disabled="@(_deleteConfirmText != "DELETE CLIENT")">
            Delete Client
        </UiButton>
        <UiButton Variant="btn btn-secondary" OnClick="@(() => _showDeleteConfirmation = false)">
            Cancel
        </UiButton>
    </Footer>
</UiModal>

<!-- Status Change Confirmation Modal -->
<UiModal @bind-IsOpen="_showStatusConfirmation"
         Title="Change Client Status"
         Size="md"
         Variant="card-glow-orange">
    <ChildContent>
        <div class="alert alert-warning">
            <strong>⚠️ Warning:</strong> Changing the client status can affect their access and functionality.
        </div>
        <p>Are you sure you want to change the status to <strong>@_pendingStatusText</strong>?</p>
    </ChildContent>
    <Footer>
        <UiButton Variant="btn btn-warning" OnClick="@ConfirmStatusChange">
            Yes, Change Status
        </UiButton>
        <UiButton Variant="btn btn-secondary" OnClick="@CancelStatusChange">
            Cancel
        </UiButton>
    </Footer>
</UiModal>

<style>
    .notes-grid {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .note-item {
        padding: 0.75rem;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 4px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        cursor: help;
    }

    .note-date {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.6);
        margin-bottom: 0.25rem;
    }

    .note-text {
        font-size: 0.875rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public Guid TenantId { get; set; }
    [Parameter] public string TenantName { get; set; } = "";
    [Parameter] public EventCallback OnSaved { get; set; }

    private TenantManagementDto? _managementData;
    private List<TenantSubscriptionPlan> _subscriptionPlans = new();
    private List<TenantStatus> _statuses = new();
    
    private bool _loading = true;
    private bool _saving = false;
    private string? _error;
    private string? _newNoteText;
    private int _maxNoteCharacters = 500;
    
    // Modal states
    private bool _showSlugConfirmation = false;
    private bool _showAddAgentModal = false;
    private bool _showDeleteConfirmation = false;
    private bool _showStatusConfirmation = false;
    
    // Form data
    private int? _selectedSubscriptionPlanId;
    private int? _selectedStatusId;
    private int? _previousStatusId;
    private string? _pendingStatusText;
    private string? _newAgentName;
    private string? _newAgentLocation;
    private string? _deleteConfirmText;

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && TenantId != Guid.Empty)
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;

        try
        {
            // Load management data
            var managementResponse = await Http.GetAsync($"api/tenants/{TenantId}/manage");
            if (managementResponse.IsSuccessStatusCode)
            {
                _managementData = await managementResponse.Content.ReadFromJsonAsync<TenantManagementDto>();
                _selectedSubscriptionPlanId = _managementData?.SubscriptionPlanId;
                _selectedStatusId = _managementData?.TenantStatusId;
                _previousStatusId = _selectedStatusId;
            }
            else
            {
                _error = $"Failed to load tenant details: {managementResponse.StatusCode}";
                return;
            }

            // Load subscription plans
            var plansResponse = await Http.GetAsync("api/tenants/subscription-plans");
            if (plansResponse.IsSuccessStatusCode)
            {
                _subscriptionPlans = await plansResponse.Content.ReadFromJsonAsync<List<TenantSubscriptionPlan>>() ?? new();
            }

            // Load statuses
            var statusesResponse = await Http.GetAsync("api/tenants/statuses");
            if (statusesResponse.IsSuccessStatusCode)
            {
                _statuses = await statusesResponse.Content.ReadFromJsonAsync<List<TenantStatus>>() ?? new();
            }
        }
        catch (Exception ex)
        {
            _error = $"Error loading data: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveChanges()
    {
        if (_managementData == null) return;

        _saving = true;
        _error = null;

        try
        {
            // Update name if changed
            if (_managementData.Name != TenantName)
            {
                var nameResponse = await Http.PutAsJsonAsync($"api/tenants/{TenantId}/name", 
                    new { Name = _managementData.Name });
                if (!nameResponse.IsSuccessStatusCode)
                {
                    _error = "Failed to update tenant name";
                    return;
                }
            }

            // Update subscription if changed
            if (_selectedSubscriptionPlanId != _managementData.SubscriptionPlanId && _selectedSubscriptionPlanId.HasValue)
            {
                var subResponse = await Http.PutAsJsonAsync($"api/tenants/{TenantId}/subscription", 
                    new { SubscriptionPlanId = _selectedSubscriptionPlanId.Value });
                if (!subResponse.IsSuccessStatusCode)
                {
                    _error = "Failed to update subscription plan";
                    return;
                }
            }

            // Check if status changed - if so, show confirmation
            if (_selectedStatusId != _previousStatusId && _selectedStatusId.HasValue)
            {
                _pendingStatusText = _statuses.FirstOrDefault(s => s.TenantStatusId == _selectedStatusId.Value)?.TenantStatusText;
                _showStatusConfirmation = true;
                _saving = false;
                return;
            }

            await OnSaved.InvokeAsync();
            await CloseModal();
        }
        catch (Exception ex)
        {
            _error = $"Error saving changes: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ConfirmStatusChange()
    {
        _showStatusConfirmation = false;
        _saving = true;

        try
        {
            var statusResponse = await Http.PutAsJsonAsync($"api/tenants/{TenantId}/status", 
                new { TenantStatusId = _selectedStatusId!.Value });
            if (!statusResponse.IsSuccessStatusCode)
            {
                _error = "Failed to update status";
                return;
            }

            _previousStatusId = _selectedStatusId;
            await OnSaved.InvokeAsync();
            await CloseModal();
        }
        catch (Exception ex)
        {
            _error = $"Error updating status: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private void CancelStatusChange()
    {
        _selectedStatusId = _previousStatusId;
        _showStatusConfirmation = false;
    }

    private void ShowGenerateSlugConfirmation()
    {
        _showSlugConfirmation = true;
    }

    private async Task GenerateNewSlug()
    {
        _showSlugConfirmation = false;
        _saving = true;

        try
        {
            var response = await Http.PostAsync($"api/tenants/{TenantId}/regenerate-slug", null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<RegenerateSlugResponse>();
                await JsRuntime.InvokeVoidAsync("alert", $"New slug generated successfully: {result?.NewSlug}");
                await LoadData();
            }
            else
            {
                _error = "Failed to generate new slug";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error generating slug: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private void ShowAddAgentModal()
    {
        _newAgentName = "";
        _newAgentLocation = "";
        _showAddAgentModal = true;
    }

    private async Task AddAgent()
    {
        if (string.IsNullOrWhiteSpace(_newAgentName)) return;

        try
        {
            var response = await Http.PostAsJsonAsync($"api/tenants/{TenantId}/agents", 
                new { Name = _newAgentName, LocationName = _newAgentLocation });
            
            if (response.IsSuccessStatusCode)
            {
                _showAddAgentModal = false;
                await LoadData();
                await JsRuntime.InvokeVoidAsync("alert", "Agent added successfully!");
            }
            else
            {
                _error = "Failed to add agent";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error adding agent: {ex.Message}";
        }
    }

    private async Task AddNote()
    {
        if (string.IsNullOrWhiteSpace(_newNoteText)) return;

        try
        {
            var response = await Http.PostAsJsonAsync($"api/tenants/{TenantId}/notes", 
                new { NoteText = _newNoteText });
            
            if (response.IsSuccessStatusCode)
            {
                _newNoteText = "";
                await LoadData();
            }
            else
            {
                _error = "Failed to add note";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error adding note: {ex.Message}";
        }
    }

    private void NavigateToAllNotes()
    {
        // TODO: Navigate to all notes page
        JsRuntime.InvokeVoidAsync("alert", "Navigation to all notes page - to be implemented");
    }

    private void ShowDeleteConfirmation()
    {
        _deleteConfirmText = "";
        _showDeleteConfirmation = true;
    }

    private async Task DeleteClient()
    {
        // TODO: Implement delete functionality
        await JsRuntime.InvokeVoidAsync("alert", "Delete client functionality - to be implemented");
        _showDeleteConfirmation = false;
    }

    private async Task Cancel()
    {
        await CloseModal();
    }

    private async Task CloseModal()
    {
        await IsOpenChanged.InvokeAsync(false);
    }

    private string GetTruncatedNoteText(string text)
    {
        const int maxLength = 80;
        if (text.Length <= maxLength) return text;
        return text.Substring(0, maxLength) + "...";
    }

    // DTOs matching the API
    private record TenantManagementDto(
        Guid TenantId,
        string Name,
        string Slug,
        int? TenantStatusId,
        string? Status,
        int? SubscriptionPlanId,
        string? Subscription,
        DateTime CreatedUtc,
        List<AgentDto> Agents,
        List<ClientNoteDto> RecentNotes
    );

    private record AgentDto(Guid Id, string Name, string? LocationName, DateTime? LastSeenUtc, string? Version);
    private record ClientNoteDto(Guid Id, string NoteText, DateTime CreatedUtc, string CreatedBy);
    private record RegenerateSlugResponse(string NewSlug);
    
    private class TenantSubscriptionPlan
    {
        public int SubscriptionPlanId { get; set; }
        public string SubscriptionPlanText { get; set; } = "";
    }

    private class TenantStatus
    {
        public int TenantStatusId { get; set; }
        public string TenantStatusText { get; set; } = "";
    }
}
