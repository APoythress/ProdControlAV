@using System.Net.Http
@using System.Net.Http.Json
@using ProdControlAV.WebApp.Components.Ui
@inject HttpClient Http

@* DTO classes must be defined locally since WebApp doesn't reference API project *@

<UiModal @bind-IsOpen="@IsOpen"
         Title="@DeviceName"
         SubTitle="ATEM Switcher Control"
         Size="xl"
         Variant="card-glow-purple">
    <ChildContent>
        @if (_isLoading)
        {
            <div class="center" style="padding: 40px;">
                <p class="muted">Loading ATEM state...</p>
            </div>
        }
        else if (_error != null)
        {
            <div class="card pad card-muted" style="background: rgba(255,77,109,.10); border-color: rgba(255,77,109,.22);">
                <p style="color: var(--red);">@_error</p>
            </div>
        }
        else if (_state != null)
        {
            <!-- Destination Selector and Current Source -->
            <div class="row between" style="margin-bottom: 20px;">
                <div style="flex: 1; max-width: 280px;">
                    <label class="label" style="margin-bottom: 8px;">Destination</label>
                    <select class="select" @bind="_selectedDestination" @bind:after="OnDestinationChanged">
                        @foreach (var dest in _state.Destinations)
                        {
                            <option value="@dest.Id">@dest.Name</option>
                        }
                    </select>
                </div>
                <div style="flex: 1; text-align: right;">
                    <label class="label" style="margin-bottom: 8px;">Current Live Source</label>
                    <div style="font-size: 24px; font-weight: 700; color: var(--text); margin-top: 4px;">
                        @GetCurrentSourceName()
                    </div>
                </div>
            </div>

            <!-- Input Buttons Grid -->
            <div class="atem-input-grid">
                @foreach (var input in GetCurrentPageInputs())
                {
                    <button class="atem-input-btn @(IsCurrentSource(input.InputId) ? "active" : "")"
                            @onclick="() => SelectInput(input.InputId)">
                        <div class="input-name">@input.Name</div>
                        <div class="input-number">@input.InputId</div>
                        @if (IsCurrentSource(input.InputId))
                        {
                            <div class="live-indicator">LIVE</div>
                        }
                    </button>
                }
            </div>

            <!-- Pagination -->
            @if (_totalPages > 1)
            {
                <div class="row center" style="margin-top: 20px; gap: 8px;">
                    @for (int i = 1; i <= _totalPages; i++)
                    {
                        var pageNumber = i;
                        <button class="page-btn @(_currentPage == pageNumber ? "active" : "")"
                                @onclick="() => SetPage(pageNumber)">
                            @pageNumber
                        </button>
                    }
                </div>
            }

            <!-- Control Buttons -->
            <div class="row center" style="margin-top: 24px; gap: 16px;">
                <UiButton Class="btn-atem-cut"
                          Variant="btn"
                          OnClick="ExecuteCut"
                          Disabled="@(_selectedInputId == null || _isExecuting)">
                    CUT
                </UiButton>
                <UiButton Class="btn-atem-auto"
                          Variant="btn-primary"
                          OnClick="ExecuteAuto"
                          Disabled="@(_selectedInputId == null || _isExecuting)">
                    AUTO
                </UiButton>
            </div>

            @if (_resultMessage != null)
            {
                <div class="card pad card-muted" style="margin-top: 16px; text-align: center;">
                    <p style="color: @(_resultSuccess ? "var(--green)" : "var(--red)");">@_resultMessage</p>
                </div>
            }
        }
    </ChildContent>
</UiModal>

<style>
    .atem-input-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-top: 16px;
    }

    .atem-input-btn {
        position: relative;
        aspect-ratio: 1;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, .12);
        background: linear-gradient(180deg, rgba(255, 255, 255, .05), transparent 60%), rgba(15, 22, 33, .92);
        cursor: pointer;
        transition: all 160ms cubic-bezier(.2, .8, .2, 1);
        padding: 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .atem-input-btn:hover {
        transform: translateY(-2px);
        border-color: rgba(139, 92, 255, .35);
        background: rgba(139, 92, 255, .12);
    }

    .atem-input-btn.active {
        border-color: rgba(78, 226, 156, .40);
        background: rgba(78, 226, 156, .15);
        box-shadow: 0 0 0 2px rgba(78, 226, 156, .20);
    }

    .input-name {
        font-size: 13px;
        font-weight: 650;
        color: var(--text);
        text-align: center;
    }

    .input-number {
        font-size: 28px;
        font-weight: 800;
        color: rgba(255, 255, 255, .85);
        line-height: 1;
    }

    .live-indicator {
        position: absolute;
        top: 8px;
        right: 8px;
        padding: 2px 6px;
        border-radius: 4px;
        background: var(--green);
        color: #000;
        font-size: 9px;
        font-weight: 800;
        letter-spacing: 0.5px;
    }

    .page-btn {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, .12);
        background: rgba(255, 255, 255, .04);
        color: var(--text);
        cursor: pointer;
        transition: all 140ms;
        font-size: 12px;
        font-weight: 600;
    }

    .page-btn:hover {
        background: rgba(255, 255, 255, .08);
        border-color: rgba(255, 255, 255, .18);
    }

    .page-btn.active {
        background: rgba(139, 92, 255, .25);
        border-color: rgba(139, 92, 255, .35);
    }

    .btn-atem-cut {
        min-width: 140px;
        height: 44px;
        font-size: 15px;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .btn-atem-auto {
        min-width: 140px;
        height: 44px;
        font-size: 15px;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    @@media (max-width: 768px) {
        .atem-input-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public Guid DeviceId { get; set; }
    [Parameter] public string DeviceName { get; set; } = string.Empty;

    private AtemStateDto? _state;
    private bool _isLoading = false;
    private string? _error;
    private string _selectedDestination = "Program";
    private long? _selectedInputId;
    private int _currentPage = 1;
    private int _totalPages = 1;
    private const int InputsPerPage = 8;
    private const int MaxPages = 5;
    private bool _isExecuting = false;
    private string? _resultMessage;
    private bool _resultSuccess = false;

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && _state == null)
        {
            await LoadState();
        }
    }

    private async Task LoadState()
    {
        _isLoading = true;
        _error = null;
        _resultMessage = null;

        try
        {
            var response = await Http.GetAsync($"/api/atem/{DeviceId}/state");
            if (response.IsSuccessStatusCode)
            {
                _state = await response.Content.ReadFromJsonAsync<AtemStateDto>();
                if (_state?.Inputs != null)
                {
                    _totalPages = Math.Min((int)Math.Ceiling(_state.Inputs.Count / (double)InputsPerPage), MaxPages);
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
            {
                _error = "You do not have permission to control ATEM devices. Please contact your administrator.";
            }
            else
            {
                _error = "Failed to load ATEM state. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private List<AtemInputDto> GetCurrentPageInputs()
    {
        if (_state?.Inputs == null) return new List<AtemInputDto>();

        var skip = (_currentPage - 1) * InputsPerPage;
        return _state.Inputs.Skip(skip).Take(InputsPerPage).ToList();
    }

    private void SetPage(int page)
    {
        _currentPage = page;
        _selectedInputId = null; // Clear selection when changing page
        _resultMessage = null;
    }

    private void SelectInput(long inputId)
    {
        _selectedInputId = inputId;
        _resultMessage = null;
    }

    private string GetCurrentSourceName()
    {
        if (_state?.Destinations == null) return "—";

        var dest = _state.Destinations.FirstOrDefault(d => d.Id == _selectedDestination);
        if (dest?.CurrentInputId == null) return "—";

        var input = _state.Inputs?.FirstOrDefault(i => i.InputId == dest.CurrentInputId);
        return input?.Name ?? $"Input {dest.CurrentInputId}";
    }

    private bool IsCurrentSource(long inputId)
    {
        if (_state?.Destinations == null) return false;

        var dest = _state.Destinations.FirstOrDefault(d => d.Id == _selectedDestination);
        return dest?.CurrentInputId == inputId;
    }

    private void OnDestinationChanged()
    {
        _resultMessage = null;
    }

    private async Task ExecuteCut()
    {
        if (_selectedInputId == null) return;

        _isExecuting = true;
        _resultMessage = null;

        try
        {
            var request = new AtemControlRequest
            {
                Destination = _selectedDestination,
                InputId = _selectedInputId.Value
            };

            var response = await Http.PostAsJsonAsync($"/api/atem/{DeviceId}/cut", request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AtemControlResponse>();
                _resultMessage = result?.Message ?? "CUT executed successfully";
                _resultSuccess = true;

                // Update current source in state
                UpdateCurrentSource(_selectedInputId.Value);
            }
            else
            {
                _resultMessage = "Failed to execute CUT";
                _resultSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _resultMessage = $"Error: {ex.Message}";
            _resultSuccess = false;
        }
        finally
        {
            _isExecuting = false;
        }
    }

    private async Task ExecuteAuto()
    {
        if (_selectedInputId == null) return;

        _isExecuting = true;
        _resultMessage = null;

        try
        {
            var request = new AtemControlRequest
            {
                Destination = _selectedDestination,
                InputId = _selectedInputId.Value
            };

            var response = await Http.PostAsJsonAsync($"/api/atem/{DeviceId}/auto", request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AtemControlResponse>();
                _resultMessage = result?.Message ?? "AUTO transition executed successfully";
                _resultSuccess = true;

                // Update current source in state
                UpdateCurrentSource(_selectedInputId.Value);
            }
            else
            {
                _resultMessage = "Failed to execute AUTO";
                _resultSuccess = false;
            }
        }
        catch (Exception ex)
        {
            _resultMessage = $"Error: {ex.Message}";
            _resultSuccess = false;
        }
        finally
        {
            _isExecuting = false;
        }
    }

    private void UpdateCurrentSource(long inputId)
    {
        if (_state?.Destinations == null) return;

        var dest = _state.Destinations.FirstOrDefault(d => d.Id == _selectedDestination);
        if (dest != null)
        {
            dest.CurrentInputId = inputId;
        }
    }
    
    // DTO classes (mirror API DTOs for WebApp)
    public class AtemInputDto
    {
        public long InputId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
    }

    public class AtemDestinationDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public long? CurrentInputId { get; set; }
    }

    public class AtemStateDto
    {
        public List<AtemInputDto> Inputs { get; set; } = new();
        public List<AtemDestinationDto> Destinations { get; set; } = new();
    }

    public class AtemControlRequest
    {
        public string Destination { get; set; } = string.Empty;
        public long InputId { get; set; }
    }

    public class AtemControlResponse
    {
        public bool Success { get; set; }
        public string Message { get; set; } = string.Empty;
    }
}
