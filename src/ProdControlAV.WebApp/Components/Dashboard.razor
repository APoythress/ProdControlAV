@page "/dashboard"
@using ProdControlAV.WebApp.Services
@using Microsoft.AspNetCore.Components.Web
@using ProdControlAV.WebApp.Models
@inject DeviceService DeviceService

<PageTitle>Device Dashboard</PageTitle>

<h1 class="text-white text-3xl mb-4">Device Control Dashboard</h1>

@if (devices is null)
{
    <p class="text-white">Loading devices...</p>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var device in devices)
        {
            <div class="bg-gray-800 p-4 rounded-2xl shadow-md">
                <h2 class="text-xl font-semibold text-white">@device.Name</h2>
                <p class="text-gray-300">@device.IP</p>
                <p class="text-gray-400">Status: <span class="@(device.IsOnline ? "text-green-400" : "text-red-400")">@(device.IsOnline ? "Online" : "Offline")</span></p>
                <p class="text-gray-400">Ping: @device.LastPingMs ms</p>
                <div class="mt-2 flex gap-2">
                    <button class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-1 rounded" @onclick="() => Ping(device)">Ping</button>
                    <button class="bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-1 rounded" @onclick="() => Reboot(device)">Reboot</button>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<DeviceStatusDto>? devices;

    protected override async Task OnInitializedAsync()
    {
        devices = await DeviceService.GetAllDevicesAsync();
        _ = PeriodicRefresh();
    }

    private async Task Ping(DeviceStatusDto device)
    {
        device.LastPingMs = await DeviceService.PingDeviceAsync(device.IP);
        device.IsOnline = device.LastPingMs >= 0;
        StateHasChanged();
    }

    private async Task Reboot(DeviceStatusDto device)
    {
        await DeviceService.SendCommandAsync(device.IP, "reboot");
    }

    private async Task PeriodicRefresh()
    {
        while (true)
        {
            await Task.Delay(30000); // refresh every 30 seconds
            devices = await DeviceService.GetAllDevicesAsync();
            StateHasChanged();
        }
    }
}
